---
const pathname = Astro.url.pathname;
const isDispatch = pathname === '/dispatch' || pathname.startsWith('/dispatch/');
const isReviews = ['/reviews','/gear','/table','/chow','/transit','/coord'].some(
  p => pathname === p || pathname.startsWith(p + '/')
);
const isLifestyle = pathname === '/lifestyle' || pathname.startsWith('/lifestyle/');
const isAbout = pathname === '/about' || pathname.startsWith('/about/');
---
<header>
  <div class="nav-wrap">
    <a class="brand" href="/">OTD <span>VAULT</span></a>
    <nav>
      <a href="/about" class={isAbout ? 'active' : ''}>ABOUT: OLD TEXAS DUDE</a>
      <a href="/dispatch" class={isDispatch ? 'active' : ''}>DISPATCH ARCHIVES</a>
      <a href="/reviews" class={isReviews ? 'active' : ''}>REVIEWS &amp; GEAR</a>
      <a href="/lifestyle" class={isLifestyle ? 'active' : ''}>LIFESTYLE</a>
    </nav>
  </div>
</header>
