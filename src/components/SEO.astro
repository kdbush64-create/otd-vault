---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  isArticle?: boolean;
}
const { title, description = 'v64otd.com — Vintage64TX', ogImage, isArticle = false } = Astro.props;
const siteTitle = title.includes('v64otd') ? title : `${title} | v64otd.com`;
const rawPath = Astro.url.pathname;
const canonicalURL = new URL(rawPath.endsWith('/') ? rawPath : rawPath + '/', Astro.site ?? 'https://v64otd.com');
const defaultOgImage = 'https://v64otd.com/images/FTW_interchange.jpg';
const resolvedOgImage = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `https://v64otd.com${ogImage}`)
  : defaultOgImage;
---
<title>{siteTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta property="og:type" content={isArticle ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={siteTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:site_name" content="v64otd.com" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@Vintage64TX" />
<meta name="twitter:title" content={siteTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />
