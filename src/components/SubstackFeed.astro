---
// ACTION REQUIRED before Session 4-D: replace with your real Substack URL
const SUBSTACK_URL = 'https://yourname.substack.com';
const TAG = 'v64otd';

let posts: Array<{ title: string; link: string; description: string; date: string }> = [];
let error: string | null = null;

try {
  const res = await fetch(`${SUBSTACK_URL}/feed?tag=${TAG}`);
  const xml = await res.text();
  const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)];
  posts = items.map(([, block]) => {
    const get = (tag: string) => {
      const m = block.match(
        new RegExp(
          `<${tag}[^>]*><!\\[CDATA\\[([\\s\\S]*?)\\]\\]><\\/${tag}>` +
          `|<${tag}[^>]*>([^<]*)<\\/${tag}>`
        )
      );
      return m ? (m[1] || m[2] || '').trim() : '';
    };
    const link = block.match(/<link>([^<]+)<\/link>/)?.[1]?.trim() ?? '';
    const pubDate = block.match(/<pubDate>([^<]+)<\/pubDate>/)?.[1]?.trim() ?? '';
    return {
      title: get('title'),
      link,
      description: get('description').replace(/<[^>]+>/g, '').slice(0, 240) + '...',
      date: pubDate
        ? new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
        : '',
    };
  });
} catch (_e) {
  error = 'Unable to load newsletter feed. Visit Substack directly.';
}
---
{error ? (
  <p class="feed-error">{error}</p>
) : (
  <ul class="substack-feed">
    {posts.map(post => (
      <li class="feed-item">
        <a href={post.link} target="_blank" rel="noopener noreferrer">
          <h3 class="feed-title">{post.title}</h3>
        </a>
        <time class="feed-date">{post.date}</time>
        <p class="feed-excerpt">{post.description}</p>
        <a class="read-link" href={post.link} target="_blank" rel="noopener noreferrer">
          Read on Substack →
        </a>
      </li>
    ))}
  </ul>
)}
