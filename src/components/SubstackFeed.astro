---
const SUBSTACK_URL = 'https://v64otd.substack.com';
---
<div id="substack-feed-container">
  <p style="color:var(--secondary); font-size:0.85rem; letter-spacing:1px;">LOADING FEED...</p>
</div>

<script define:vars={{ SUBSTACK_URL }}>
  async function loadFeed() {
    const container = document.getElementById('substack-feed-container');
    try {
      const res = await fetch(`${SUBSTACK_URL}/feed`);
      const xml = await res.text();
      const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)];

      if (items.length === 0) {
        container.innerHTML = '<p style="color:var(--secondary);">No posts found. <a href="' + SUBSTACK_URL + '" target="_blank" style="color:var(--accent);">Visit Substack directly →</a></p>';
        return;
      }

      const posts = items.map(([, block]) => {
        const get = (tag) => {
          const m = block.match(
            new RegExp(
              `<${tag}[^>]*><!\\[CDATA\\[([\\s\\S]*?)\\]\\]><\\/${tag}>` +
              `|<${tag}[^>]*>([^<]*)<\\/${tag}>`
            )
          );
          return m ? (m[1] || m[2] || '').trim() : '';
        };
        const link = block.match(/<link>([^<]+)<\/link>/)?.[1]?.trim() ?? '';
        const pubDate = block.match(/<pubDate>([^<]+)<\/pubDate>/)?.[1]?.trim() ?? '';
        return {
          title: get('title'),
          link,
          description: get('description').replace(/<[^>]+>/g, '').slice(0, 240) + '...',
          date: pubDate
            ? new Date(pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
            : '',
        };
      });

      container.innerHTML = `<ul class="substack-feed">${posts.map(post => `
        <li class="feed-item">
          <a href="${post.link}" target="_blank" rel="noopener noreferrer" style="color:var(--accent); text-decoration:none;">
            <h3 class="feed-title" style="color:var(--accent);">${post.title}</h3>
          </a>
          <time class="feed-date" style="color:var(--secondary);">${post.date}</time>
          <p class="feed-excerpt">${post.description}</p>
          <a class="read-link" href="${post.link}" target="_blank" rel="noopener noreferrer" style="color:var(--accent); text-decoration:none;">Read on Substack →</a>
        </li>`).join('')}
      </ul>`;

    } catch (_e) {
      container.innerHTML = '<p style="color:var(--secondary);">Unable to load feed. <a href="' + SUBSTACK_URL + '" target="_blank" style="color:var(--accent);">Visit Substack directly →</a></p>';
    }
  }

  loadFeed();
</script>
