---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  showHero?: boolean;
  isArticle?: boolean;
}
const { title, description = 'v64otd.com — Vintage64TX', ogImage, showHero = false, isArticle = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-BHFJD28SFL"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-BHFJD28SFL');
</script>   
<meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO title={title} description={description} ogImage={ogImage} isArticle={isArticle} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="stylesheet" href="/style.css" />
    <link rel="manifest" href="/manifest.webmanifest" />
      </head>
  <body id="personal-identity">
    <div class="terminal-overlay"></div>
    <div class="container">
      <Header showHero={showHero} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
