  .tag-chip:hover { background: var(--cedar); color: #fff; }
</style>
<script is:inline>
  (function () {
    var dataEl = document.getElementById('gallery-json');
    if (!dataEl) return;
    var photos = JSON.parse(dataEl.textContent || '[]');
    if (!photos.length) return;
    var lightbox = document.getElementById('review-lightbox');
    var lbImg = document.getElementById('lb-img');
    var lbCaption = document.getElementById('lb-caption');
    var lbCounter = document.getElementById('lb-counter');
    var lbClose = document.getElementById('lb-close');
    var lbPrev = document.getElementById('lb-prev');
    var lbNext = document.getElementById('lb-next');
    var current = 0;
    function show(i) {
      current = ((i % photos.length) + photos.length) % photos.length;
      lbImg.src = photos[current].src;
      lbImg.alt = photos[current].caption || 'Photo ' + (current + 1);
      lbCaption.textContent = photos[current].caption;
      lbCounter.textContent = (current + 1) + ' / ' + photos.length;
    }
    function openLightbox(i) {
      show(i);
      lightbox.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      lbClose.focus();
    }
    function closeLightbox() {
      lightbox.setAttribute('hidden', '');
      document.body.style.overflow = '';
    }
    document.querySelectorAll('.thumb-btn').forEach(function (btn) {
      btn.addEventListener('click', function () { openLightbox(Number(btn.dataset.index)); });
    });
    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', function () { show(current - 1); });
    lbNext.addEventListener('click', function () { show(current + 1); });
    lightbox.addEventListener('click', function (e) {
      if (e.target === lightbox) closeLightbox();
    });
    document.addEventListener('keydown', function (e) {
      if (lightbox.hasAttribute('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  })();
</script>
