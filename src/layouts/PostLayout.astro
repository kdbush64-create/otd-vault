---
import BaseLayout from './BaseLayout.astro';
import StarRating from '../components/StarRating.astro';
interface Props {
  title: string;
  slug?: string;
  description?: string;
  date?: string;
  channel?: string;
  rating?: string;
  cost?: string;
  foodType?: string;
  address?: string;
  website?: string;
  gallery?: { image: string; caption?: string }[];
  affiliate?: boolean;
  affiliateLinks?: { label: string; url: string }[];
  tags?: string;
}
const { title, slug, description, date, channel, rating, cost, foodType, address, website, gallery, affiliate, affiliateLinks, tags } = Astro.props;
const tagList = tags
  ? (Array.isArray(tags) ? (tags as string[]) : String(tags).trim().split(/\s+/)).filter(Boolean)
  : [];
const channelMap: Record<string, string> = {
  dispatch: 'THE DISPATCH',
  transit: 'TRANSIT',
  gear: 'GEAR',
  coord: 'COORD',
  table: 'THE TABLE',
  chow: 'THE KITCHEN',
};
const channelLabel = channel ? (channelMap[channel] ?? channel.toUpperCase()) : null;
const hasReviewMeta = rating || cost || foodType || address || website;
function nthSundayOf(year: number, month: number, n: number): Date {
  const first = new Date(year, month - 1, 1);
  const daysUntilSunday = (7 - first.getDay()) % 7;
  return new Date(year, month - 1, 1 + daysUntilSunday + (n - 1) * 7);
}
function isInCDT(datePart: string): boolean {
  const [year, month, day] = datePart.split('-').map(Number);
  const d = new Date(year, month - 1, day);
  return d >= nthSundayOf(year, 3, 2) && d < nthSundayOf(year, 11, 1);
}
function formatDispatchTime(dateStr: string): string | null {
  if (!dateStr || !dateStr.includes('T')) return null;
  try {
    const clean = dateStr.split('.')[0].replace('Z', '');
    const [hourStr, minuteStr] = clean.split('T')[1].split(':');
    const hour = parseInt(hourStr, 10);
    const minute = parseInt(minuteStr, 10);
    const datePart = clean.split('T')[0];
    const hour12 = hour % 12 || 12;
    const ampm = hour >= 12 ? 'PM' : 'AM';
    const tz = isInCDT(datePart) ? 'CDT' : 'CST';
    return `${String(hour12).padStart(2,'0')}:${String(minute).padStart(2,'0')}${ampm}-${tz}`;
  } catch (e) { return null; }
}
const datePart = date ? date.split('T')[0] : undefined;
const dispatchTime = channel === 'dispatch' ? formatDispatchTime(date ?? '') : null;
const siteUrl = 'https://v64otd.com';
const postUrl = `${siteUrl}/${channel}/${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
const shareText = encodeURIComponent(`${title} — ${siteUrl}`);
const xShareUrl = `https://x.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(postUrl)}`;
const fbShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(postUrl)}`;
const ratingSlug = slug ?? `${channel}/${title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`;
const showRating = channel === 'dispatch' || channel === 'chow';
---
<BaseLayout title={`${title} | OTD Vault`} description={description} ogImage={gallery?.[0]?.image} isArticle={true}>
  <nav class="secondary-filters" style="margin-bottom: 20px; border-bottom: 1px dashed var(--border); padding-bottom: 16px;">
    {channel && (
      <a href={`/${channel}`} class="submit-btn" style="text-decoration:none;">&laquo; {channelLabel}</a>
    )}
  </nav>
  <div class="vault-layout">
    <section class="log-display" style="width:100%;">
      <article class="blog-post">
        <div class="blog-post-body">
          {channel && (
            <p style="color:var(--secondary); font-size:0.75rem; letter-spacing:1px; margin-bottom:5px;">[{channel.toUpperCase()}_LOG]</p>
          )}
          <h1 style="color:var(--primary); font-size:1.3rem; margin-bottom:8px; line-height:1.3;">{title}</h1>
          {datePart && (
            <time style="color:var(--secondary); font-size:0.78rem; opacity:0.7; display:block; margin-bottom:8px;">
              {new Date(datePart + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              {dispatchTime && (
                <span style="margin-left: 8px; opacity: 0.75;">{dispatchTime}</span>
              )}
            </time>
          )}
          {showRating && (
            <div style="margin-bottom: 16px;">
              <StarRating slug={ratingSlug} interactive={true} />
            </div>
          )}
          {affiliate && (
            <div style="border: 1px dashed var(--secondary); padding: 8px 14px; margin-bottom: 16px; font-size: 0.78rem; color: var(--secondary); opacity: 0.8;">
              ⚠ This post contains affiliate links. If you purchase through these links, I may earn a small commission at no extra cost to you.
              <a href="/pages/gear-policy" style="color:var(--secondary); margin-left:6px;">Affiliate Policy →</a>
            </div>
          )}
          {hasReviewMeta && (
            <div style="border: 1px dashed var(--border); padding: 10px 14px; margin-bottom: 20px; font-size: 0.82rem; display: flex; flex-wrap: wrap; gap: 16px;">
              {rating && (
                <span>
                  <span style="color:var(--primary); letter-spacing:1px;">RATING</span>&nbsp;
                  <strong style="color:var(--secondary);">{rating}/10</strong>
                </span>
              )}
              {cost && (
                <span>
                  <span style="color:var(--primary); letter-spacing:1px;">COST</span>&nbsp;
                  <strong style="color:var(--secondary);">{cost}</strong>
                </span>
              )}
              {foodType && (
                <span>
                  <span style="color:var(--primary); letter-spacing:1px;">TYPE</span>&nbsp;
                  <strong style="color:var(--secondary);">{foodType}</strong>
                </span>
              )}
              {address && (
                <span>
                  <span style="color:var(--primary); letter-spacing:1px;">LOCATION</span>&nbsp;
                  <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    style="color:var(--accent); text-decoration:none;"
                  >
                    {address} →
                  </a>
                </span>
              )}
              {website && (
                <span>
                  <span style="color:var(--primary); letter-spacing:1px;">WEBSITE</span>&nbsp;
                  <a href={website} target="_blank" rel="noopener noreferrer" style="color:var(--secondary); text-decoration:none;">
                    {website.replace(/^https?:\/\//, '').replace(/\/$/, '')} →
                  </a>
                </span>
              )}
            </div>
          )}
          {gallery && gallery.length > 0 && (
            gallery.length === 1 ? (
              <figure style="margin: 0 0 24px 0;">
                <img
                  src={gallery[0].image}
                  alt={gallery[0].caption || title}
                  style="width: 100%; max-height: 480px; object-fit: cover; border: 1px dashed var(--border); display: block;"
                />
                {gallery[0].caption && (
                  <figcaption style="color: var(--secondary); font-size: 0.72rem; margin-top: 4px; text-align: center;">
                    {gallery[0].caption}
                  </figcaption>
                )}
              </figure>
            ) : (
              <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; margin-bottom: 24px;">
                {gallery.map(item => (
                  <figure style="margin: 0;">
                    <img
                      src={item.image}
                      alt={item.caption || title}
                      style="width: 100%; height: 180px; object-fit: cover; border: 1px dashed var(--border); display: block;"
                    />
                    {item.caption && (
                      <figcaption style="color: var(--secondary); font-size: 0.72rem; margin-top: 4px; text-align: center;">
                        {item.caption}
                      </figcaption>
                    )}
                  </figure>
                ))}
              </div>
            )
          )}
          <hr style="border:none; border-top:1px dashed var(--border); margin-bottom:20px;" />
          <slot />
          {tagList.length > 0 && (
            <div style="margin-top: 24px; display: flex; flex-wrap: wrap; gap: 8px;">
              {tagList.map(tag => (
                <a href={`/tags/${tag}`} style="color:var(--accent); font-size:0.75rem; border: 1px dashed var(--accent); padding: 3px 10px; text-decoration:none; letter-spacing:1px;">#{tag}</a>
              ))}
            </div>
          )}
          <div style="margin-top: 32px; border: 1px dashed var(--border); padding: 16px 20px;">
            <p style="color:var(--secondary); font-size:0.75rem; letter-spacing:2px; margin-bottom:12px;">[ SHARE_THIS_DISPATCH ]</p>
            <div style="display:flex; gap:16px; flex-wrap:wrap;">
              <a href={xShareUrl} target="_blank" rel="noopener noreferrer" style="color:var(--accent); text-decoration:none; font-size:0.88rem; border: 1px dashed var(--accent); padding: 6px 14px;">𝕏 Post to X →</a>
              <a href={fbShareUrl} target="_blank" rel="noopener noreferrer" style="color:var(--accent); text-decoration:none; font-size:0.88rem; border: 1px dashed var(--accent); padding: 6px 14px;">f Share on Facebook →</a>
            </div>
          </div>
          {affiliateLinks && affiliateLinks.length > 0 && (
            <div style="margin-top: 32px; border: 1px dashed var(--secondary); padding: 16px 20px;">
              <p style="color:var(--secondary); font-size:0.75rem; letter-spacing:2px; margin-bottom:12px;">[ SHOP_THIS_RECIPE ]</p>
              <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:8px;">
                {affiliateLinks.map(link => (
                  <li>
                    <a href={link.url} target="_blank" rel="noopener noreferrer nofollow" style="color:var(--accent); text-decoration:none; font-size:0.88rem;">&gt; {link.label} →</a>
                  </li>
                ))}
              </ul>
              <p style="color:var(--secondary); font-size:0.72rem; opacity:0.7; margin-top:12px;">
                ⚠ Affiliate links — I may earn a small commission at no extra cost to you.
                <a href="/pages/gear-policy" style="color:var(--secondary); margin-left:4px;">Affiliate Policy →</a>
              </p>
            </div>
          )}
        </div>
      </article>
    </section>
  </div>
</BaseLayout>
