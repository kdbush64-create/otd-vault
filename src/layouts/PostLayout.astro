---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date?: string;
  description?: string;
  tags?: string;
  channel?: string;
  image?: string;
  gallery?: { image: string; caption?: string }[];
  rating?: string;
  cost?: string;
  affiliateLinks?: { label: string; url: string; priceNoted?: string }[];
  callToAction?: string[];
  signoff?: string;
  // Gear
  manufacturerUrl?: string;
  useCase?: string;
  pros?: string[];
  cons?: string[];
  buildQuality?: string;
  timeFieldTested?: string;
  bestFor?: string;
  wouldBuyAgain?: string;
  // The Table
  whatYouOrdered?: string;
  serviceQuality?: string;
  ambiance?: string;
  wouldReturn?: string;
  // The Kitchen
  prepTime?: string;
  cookTime?: string;
  totalTime?: string;
  servings?: string;
  difficulty?: string;
  equipmentNeeded?: string[];
  substitutionNotes?: string;
  storageNotes?: string;
  // Travel
  bestSeason?: string;
  recommendedStay?: string;
  pairWith?: string;
}

const {
  title, date, description, tags, channel = 'dispatch',
  image, gallery, rating, cost, affiliateLinks, callToAction, signoff,
  manufacturerUrl, useCase, pros, cons, buildQuality, timeFieldTested, bestFor, wouldBuyAgain,
  whatYouOrdered, serviceQuality, ambiance, wouldReturn,
  prepTime, cookTime, totalTime, servings, difficulty, equipmentNeeded, substitutionNotes, storageNotes,
  bestSeason, recommendedStay, pairWith,
} = Astro.props;

const tagList = tags
  ? (Array.isArray(tags)
      ? (tags as string[]).flatMap(t => t.trim().split(/\s+/))
      : String(tags).trim().split(/\s+/))
    .filter(Boolean)
  : [];

const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const isDispatch = channel === 'dispatch';
const isLifestyle = channel === 'lifestyle';
const isDispatchLike = isDispatch || isLifestyle; // Lifestyle = Dispatch's look + affiliate links
const isReview = ['gear', 'table', 'chow', 'transit', 'coord'].includes(channel);

const channelLabels: Record<string, string> = {
  dispatch: 'Dispatch', gear: 'Gear', table: 'The Table',
  chow: 'The Kitchen', transit: 'Travel', coord: 'Getaways',
  lifestyle: 'Lifestyle',
};
const channelLabel = channelLabels[channel] ?? channel;
const channelHref = isDispatch ? '/dispatch' : isLifestyle ? '/lifestyle' : '/reviews';

// Use first gallery image as hero for reviews if no standalone image
const heroImage = image ?? (gallery && gallery.length > 0 ? gallery[0].image : undefined);
const remainingGallery = image
  ? gallery
  : gallery && gallery.length > 1 ? gallery.slice(1) : undefined;

// Always produce an absolute URL for og:image (Mastodon/X/Bridgy Fed require absolute URLs)
const ogImageAbsolute = heroImage
  ? (heroImage.startsWith('http') ? heroImage : 'https://v64otd.com' + heroImage)
  : 'https://v64otd.com/images/FTW_interchange.jpg';

// Permalink for Bridgy Fed's u-url — Astro's own knowledge of the current page's exact URL
const permalink = Astro.url.href;

// Does this page have any structured review-detail fields worth showing? (Review zone only)
const hasDetails = Boolean(
  useCase || whatYouOrdered || serviceQuality || ambiance || buildQuality || timeFieldTested ||
  prepTime || cookTime || totalTime || servings || difficulty || bestSeason || recommendedStay ||
  bestFor || manufacturerUrl || pairWith || substitutionNotes || storageNotes ||
  (equipmentNeeded && equipmentNeeded.length > 0) ||
  (pros && pros.length > 0) || (cons && cons.length > 0) ||
  wouldBuyAgain || wouldReturn
);
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImageAbsolute}
  isArticle={true}
>
  <article class={'post-article h-entry channel-' + channel}>

    <!-- Bridgy Fed: permalink + verification link (required for webmention delivery, not just acceptance) -->
    <a href={permalink} class="u-url" hidden></a>
    <a class="u-bridgy-fed" href="https://fed.brid.gy/" hidden="from-humans"></a>

    <!-- Article image for Bridgy Fed/Mastodon syndication -->
    {heroImage && (
      <img
        class="u-photo"
        src={heroImage.startsWith('http') ? heroImage : 'https://v64otd.com' + heroImage}
        alt={title}
        style="display:none"
      />
    )}

    <!-- Breadcrumb -->
    <nav class="post-breadcrumb" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href={channelHref}>{isDispatch ? 'Dispatch' : isLifestyle ? 'Lifestyle' : 'Reviews'}</a>
      {!isDispatchLike && (
        <>
          <span aria-hidden="true">›</span>
          <a href={'/' + channel}>{channelLabel}</a>
        </>
      )}
    </nav>

    <!-- Post Header — identical for Dispatch and Lifestyle -->
    <header class="post-header">
      <h1 class="post-title p-name">{title}</h1>
      {isDispatchLike && (
        <div class="dispatch-meta">
          {formattedDate && <time class="post-date dt-published" datetime={date}>{formattedDate}</time>}
          <div class="case-file-stamp" aria-label="Case File V64OTD">
            <svg viewBox="0 0 90 90" width="72" height="72" aria-hidden="true">
              <circle cx="45" cy="45" r="42" fill="none" stroke="var(--clay)" stroke-width="2.5"/>
              <circle cx="45" cy="45" r="36" fill="none" stroke="var(--clay)" stroke-width="1"/>
              <text x="45" y="34" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="7.5" fill="var(--clay)" letter-spacing="2">CASE FILE</text>
              <text x="45" y="50" text-anchor="middle" font-family="'Fraunces',serif" font-size="11" font-weight="700" fill="var(--clay)">V64OTD</text>
              <text x="45" y="63" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="6.5" fill="var(--clay)" letter-spacing="1.5">VERIFIED</text>
            </svg>
          </div>
        </div>
      )}
      {isReview && formattedDate && <time class="post-date dt-published" datetime={date}>{formattedDate}</time>}
    </header>

    <!-- Review: Hero Image with Field Tested stamp -->
    {isReview && heroImage && (
      <div class="review-image-wrap">
        <img src={heroImage} alt={title} class="review-hero-img" loading="lazy" />
        <div class="field-tested-stamp" aria-label="Field Tested V64OTD">
          <svg viewBox="0 0 90 90" width="80" height="80" aria-hidden="true">
            <circle cx="45" cy="45" r="42" fill="rgba(239,233,220,0.92)" stroke="var(--cedar)" stroke-width="2.5"/>
            <circle cx="45" cy="45" r="36" fill="none" stroke="var(--cedar)" stroke-width="1"/>
            <text x="45" y="33" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="7" fill="var(--cedar)" letter-spacing="1.5">FIELD TESTED</text>
            <text x="45" y="50" text-anchor="middle" font-family="'Fraunces',serif" font-size="11" font-weight="700" fill="var(--cedar)">V64OTD</text>
            <text x="45" y="63" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="6.5" fill="var(--cedar)" letter-spacing="1.5">VERIFIED</text>
          </svg>
        </div>
      </div>
    )}

    <!-- Dispatch/Lifestyle: gallery (all images, no hero/stamp split — same as Dispatch) -->
    {isDispatchLike && gallery && gallery.length > 0 && (
      <div class="post-gallery">
        {gallery.map(item => (
          <figure class="gallery-figure">
            <img src={item.image} alt={item.caption ?? title} loading="lazy" class="gallery-img" />
            {item.caption && <figcaption class="gallery-caption">{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    <!-- Review: remaining gallery images (after hero) -->
    {isReview && remainingGallery && remainingGallery.length > 0 && (
      <div class="post-gallery">
        {remainingGallery.map(item => (
          <figure class="gallery-figure">
            <img src={item.image} alt={item.caption ?? title} loading="lazy" class="gallery-img" />
            {item.caption && <figcaption class="gallery-caption">{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    <!-- Review: Verdict Box -->
    {isReview && (rating || cost) && (
      <div class="verdict-box">
        {rating && <div class="verdict-item"><span class="verdict-label">RATING</span><span class="verdict-value">{rating} / 5</span></div>}
        {cost && <div class="verdict-item"><span class="verdict-label">COST</span><span class="verdict-value">{cost}</span></div>}
      </div>
    )}

    <!-- Review: Structured Details Panel -->
    {isReview && hasDetails && (
      <div class="review-details">
        {useCase && <div class="detail-row"><span class="detail-label">USE CASE</span><span class="detail-value">{useCase}</span></div>}
        {whatYouOrdered && <div class="detail-row"><span class="detail-label">WHAT WE ORDERED</span><span class="detail-value">{whatYouOrdered}</span></div>}
        {serviceQuality && <div class="detail-row"><span class="detail-label">SERVICE</span><span class="detail-value">{serviceQuality}</span></div>}
        {ambiance && <div class="detail-row"><span class="detail-label">AMBIANCE</span><span class="detail-value">{ambiance}</span></div>}
        {buildQuality && <div class="detail-row"><span class="detail-label">BUILD QUALITY</span><span class="detail-value">{buildQuality}</span></div>}
        {timeFieldTested && <div class="detail-row"><span class="detail-label">TIME TESTED</span><span class="detail-value">{timeFieldTested}</span></div>}
        {prepTime && <div class="detail-row"><span class="detail-label">PREP TIME</span><span class="detail-value">{prepTime}</span></div>}
        {cookTime && <div class="detail-row"><span class="detail-label">COOK TIME</span><span class="detail-value">{cookTime}</span></div>}
        {totalTime && <div class="detail-row"><span class="detail-label">TOTAL TIME</span><span class="detail-value">{totalTime}</span></div>}
        {servings && <div class="detail-row"><span class="detail-label">SERVINGS</span><span class="detail-value">{servings}</span></div>}
        {difficulty && <div class="detail-row"><span class="detail-label">DIFFICULTY</span><span class="detail-value">{difficulty}</span></div>}
        {bestSeason && <div class="detail-row"><span class="detail-label">BEST SEASON</span><span class="detail-value">{bestSeason}</span></div>}
        {recommendedStay && <div class="detail-row"><span class="detail-label">RECOMMENDED STAY</span><span class="detail-value">{recommendedStay}</span></div>}
        {bestFor && <div class="detail-row"><span class="detail-label">BEST FOR</span><span class="detail-value">{bestFor}</span></div>}
        {manufacturerUrl && <div class="detail-row"><span class="detail-label">PRODUCT PAGE</span><span class="detail-value"><a href={manufacturerUrl} target="_blank" rel="noopener">{manufacturerUrl.replace(/^https?:\/\//,'').replace(/\/$/,'')}</a></span></div>}
        {wouldBuyAgain && <div class="detail-row"><span class="detail-label">WOULD BUY AGAIN?</span><span class="detail-value">{wouldBuyAgain === 'yes' ? 'Yes' : wouldBuyAgain === 'no' ? 'No' : wouldBuyAgain}</span></div>}
        {wouldReturn && <div class="detail-row"><span class="detail-label">WOULD RETURN?</span><span class="detail-value">{wouldReturn === 'yes' ? 'Yes' : wouldReturn === 'no' ? 'No' : wouldReturn}</span></div>}

        {pairWith && <div class="detail-block"><span class="detail-label">WHAT'S NEARBY</span><p class="detail-text">{pairWith}</p></div>}
        {substitutionNotes && <div class="detail-block"><span class="detail-label">SUBSTITUTIONS</span><p class="detail-text">{substitutionNotes}</p></div>}
        {storageNotes && <div class="detail-block"><span class="detail-label">STORAGE</span><p class="detail-text">{storageNotes}</p></div>}

        {equipmentNeeded && equipmentNeeded.length > 0 && (
          <div class="detail-block">
            <span class="detail-label">EQUIPMENT NEEDED</span>
            <ul class="detail-list">{equipmentNeeded.map(item => <li>{item}</li>)}</ul>
          </div>
        )}

        {((pros && pros.length > 0) || (cons && cons.length > 0)) && (
          <div class="pros-cons-grid">
            {pros && pros.length > 0 && (
              <div class="pros-box">
                <span class="detail-label pros-label">PROS</span>
                <ul class="detail-list">{pros.map(item => <li>{item}</li>)}</ul>
              </div>
            )}
            {cons && cons.length > 0 && (
              <div class="cons-box">
                <span class="detail-label cons-label">CONS</span>
                <ul class="detail-list">{cons.map(item => <li>{item}</li>)}</ul>
              </div>
            )}
          </div>
        )}
      </div>
    )}

    <!-- Reading-list CTA — same core line everywhere, but the "ledger" claim stays Dispatch-only -->
    {isDispatchLike && (
      <p class="dispatch-tagline">
        {isDispatch
          ? "Add v64otd.com to your daily reading list — the ledger doesn't lie."
          : "Add v64otd.com to your daily reading list."}
      </p>
    )}

    <!-- Article Body -->
    <div class="post-body e-content prose"><slot /></div>

    <!-- Dispatch/Lifestyle: Call to Action block -->
    {isDispatchLike && callToAction && callToAction.length > 0 && (
      <div class="cta-block">
        <p class="cta-label">CALL TO ACTION</p>
        <ol class="cta-list">{callToAction.map(item => <li>{item}</li>)}</ol>
      </div>
    )}

    <!-- Review/Lifestyle: Affiliate CTA -->
    {(isReview || isLifestyle) && affiliateLinks && affiliateLinks.length > 0 && (
      <div class="affiliate-block">
        <p class="affiliate-label">WHERE TO GET IT</p>
        <div class="affiliate-links">
          {affiliateLinks.map(link => (
            <div class="affiliate-link-item">
              <a href={link.url} class="affiliate-btn" target="_blank" rel="noopener sponsored">{link.label}</a>
              {link.priceNoted && <span class="affiliate-price">~{link.priceNoted} at time of review</span>}
            </div>
          ))}
        </div>
        <p class="affiliate-disclosure">This post contains affiliate links. If you purchase through them, I may earn a small commission at no extra cost to you. Any prices mentioned reflect what I saw at the time of writing — Amazon determines current pricing and availability, which will be shown when you click through.</p>
      </div>
    )}

    <!-- Dispatch/Lifestyle: Signoff — per-article field, renders only if filled in -->
    {isDispatchLike && signoff && (
      <p class="dispatch-signoff">{signoff}</p>
    )}

    <!-- Tags -->
    {tagList.length > 0 && (
      <div class="post-tags">
        {tagList.map(tag => <a href={'/tags/' + tag.toLowerCase()} class="tag-chip">#{tag}</a>)}
      </div>
    )}

  </article>
</BaseLayout>

<style>
  .post-article { max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

  .post-breadcrumb {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem; letter-spacing: 0.06em;
    color: rgba(43,37,32,0.55); margin-bottom: 1.75rem;
    display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;
  }
  .post-breadcrumb a { color: rgba(43,37,32,0.55); text-decoration: none; }
  .post-breadcrumb a:hover { color: var(--clay); }

  .post-header { margin-bottom: 1.5rem; }
  .post-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700; line-height: 1.15; color: var(--ink); margin: 0 0 1rem;
  }
  .post-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem; letter-spacing: 0.08em;
    color: rgba(43,37,32,0.5); text-transform: uppercase; display: block; margin-bottom: 0.75rem;
  }
  .dispatch-meta { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .case-file-stamp { flex-shrink: 0; opacity: 0.85; }

  .review-image-wrap { position: relative; margin: 0 0 1.5rem; border-radius: 3px; overflow: hidden; }
  .review-hero-img { display: block; width: 100%; height: auto; max-height: 420px; object-fit: cover; }
  .field-tested-stamp { position: absolute; bottom: 1rem; right: 1rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3)); }

  .post-gallery { margin: 0 0 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .gallery-figure { margin: 0; }
  .gallery-img { width: 100%; height: auto; border-radius: 3px; display: block; max-height: 480px; object-fit: cover; }
  .gallery-caption { font-family: 'IBM Plex Mono', monospace; font-size: 0.7rem; letter-spacing: 0.04em; color: rgba(43,37,32,0.5); margin-top: 0.4rem; }

  .verdict-box {
    display: flex; gap: 2rem; background: var(--card-bg);
    border: 1.5px solid var(--border); border-radius: 3px;
    padding: 1rem 1.5rem; margin-bottom: 1.75rem; flex-wrap: wrap;
  }
  .verdict-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .verdict-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; color: rgba(43,37,32,0.5); text-transform: uppercase; }
  .verdict-value { font-family: 'Fraunces', serif; font-size: 1.3rem; font-weight: 600; color: var(--ochre); }

  .review-details {
    background: var(--card-bg); border: 1.5px solid var(--border); border-radius: 3px;
    padding: 1.25rem 1.5rem; margin-bottom: 1.75rem;
    display: flex; flex-direction: column; gap: 0.85rem;
  }
  .detail-row { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; border-bottom: 1px dashed var(--border); padding-bottom: 0.6rem; }
  .detail-row:last-child { border-bottom: none; padding-bottom: 0; }
  .detail-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; color: rgba(43,37,32,0.5); text-transform: uppercase; flex-shrink: 0; }
  .detail-value { font-family: 'Inter', sans-serif; font-size: 0.92rem; color: var(--ink); text-align: right; }
  .detail-value a { color: var(--clay); }
  .detail-block { display: flex; flex-direction: column; gap: 0.4rem; }
  .detail-text { font-family: 'Inter', sans-serif; font-size: 0.92rem; color: var(--ink); margin: 0; line-height: 1.55; }
  .detail-list { margin: 0; padding-left: 1.25rem; font-family: 'Inter', sans-serif; font-size: 0.92rem; color: var(--ink); }
  .detail-list li { margin-bottom: 0.3em; }

  .pros-cons-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .pros-box, .cons-box { display: flex; flex-direction: column; gap: 0.4rem; }
  .pros-label { color: var(--cedar); }
  .cons-label { color: var(--clay); }

  .dispatch-tagline {
    font-family: 'Inter', sans-serif; font-size: 0.88rem;
    color: rgba(43,37,32,0.5); font-style: italic; margin: 0 0 2rem;
    border-left: 3px solid var(--clay); padding-left: 0.85rem;
  }

  .post-body { font-family: 'Inter', sans-serif; font-size: 1.05rem; line-height: 1.75; color: var(--ink); margin-bottom: 2.5rem; }
  .post-body :global(h2) { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 600; margin: 2rem 0 0.75rem; color: var(--ink); }
  .post-body :global(h3) { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--ink); }
  .post-body :global(p) { margin: 0 0 1.25em; }
  .post-body :global(a) { color: var(--clay); text-underline-offset: 3px; }
  .post-body :global(blockquote) { border-left: 3px solid var(--clay); margin: 1.5rem 0; padding: 0.5rem 1rem; color: rgba(43,37,32,0.7); font-style: italic; }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.5rem; margin: 0 0 1.25em; }
  .post-body :global(li) { margin-bottom: 0.4em; }
  .post-body :global(code) { font-family: 'IBM Plex Mono', monospace; font-size: 0.88em; background: rgba(43,37,32,0.07); padding: 0.1em 0.3em; border-radius: 2px; }
  .post-body :global(img) { max-width: 100%; height: auto; border-radius: 3px; margin: 1.5rem 0; display: block; }

  .cta-block {
    background: var(--card-bg); border: 1.5px solid var(--border);
    border-left: 4px solid var(--clay); border-radius: 3px;
    padding: 1.25rem 1.5rem; margin: 0 0 2rem;
  }
  .cta-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; letter-spacing: 0.14em; color: var(--clay); margin: 0 0 0.75rem; text-transform: uppercase; }
  .cta-list { margin: 0; padding-left: 1.4rem; font-family: 'Inter', sans-serif; font-size: 0.98rem; line-height: 1.65; color: var(--ink); }
  .cta-list li { margin-bottom: 0.45em; }

  .dispatch-signoff {
    font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em;
    color: rgba(43,37,32,0.45); text-transform: uppercase; text-align: right;
    margin: 0 0 2rem; padding-top: 1rem; border-top: 1px solid var(--border);
  }

  .affiliate-block { background: var(--ink); color: var(--bg-limestone); border-radius: 3px; padding: 1.5rem; margin: 0 0 2rem; }
  .affiliate-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; letter-spacing: 0.14em; color: var(--ochre); margin: 0 0 1rem; text-transform: uppercase; }
  .affiliate-links { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1rem; }
  .affiliate-link-item { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .affiliate-btn { font-family: 'IBM Plex Mono', monospace; font-size: 0.8rem; background: var(--clay); color: #fff; text-decoration: none; padding: 0.55rem 1rem; border-radius: 2px; transition: opacity 0.15s; }
  .affiliate-btn:hover { opacity: 0.85; }
  .affiliate-price { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; color: rgba(239,233,220,0.6); }
  .affiliate-disclosure { font-family: 'Inter', sans-serif; font-size: 0.75rem; color: rgba(239,233,220,0.5); margin: 0; line-height: 1.5; }

  .post-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  .tag-chip { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; background: rgba(107,122,94,0.12); color: var(--cedar); padding: 0.3rem 0.7rem; border-radius: 20px; text-decoration: none; transition: background 0.15s, color 0.15s; }
  .tag-chip:hover { background: var(--cedar); color: #fff; }
</style>
