---
import BaseLayout from './BaseLayout.astro';
interface Props {
  title: string;
  date?: string;
  description?: string;
  tags?: string;
  channel?: string;
  image?: string;
  gallery?: { image: string; caption?: string }[];
  rating?: string;
  cost?: string;
  affiliateLinks?: { label: string; url: string; priceNoted?: string }[];
  callToAction?: string[];
  signoff?: string;
  foodType?: string;
  whatYouOrdered?: string;
  serviceQuality?: string;
  ambiance?: string;
  bestFor?: string;
  wouldReturn?: string;
}
const {
  title, date, description, tags, channel = 'dispatch',
  image, gallery, rating, cost, affiliateLinks, callToAction, signoff,
  foodType, whatYouOrdered, serviceQuality, ambiance, bestFor, wouldReturn,
} = Astro.props;
const tagList = tags
  ? (Array.isArray(tags)
      ? (tags as string[]).flatMap(t => t.trim().split(/\s+/))
      : String(tags).trim().split(/\s+/))
    .filter(Boolean)
  : [];
const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
const isDispatch = channel === 'dispatch';
const isReview = ['gear', 'table', 'chow', 'transit', 'coord'].includes(channel);
const isLifestyle = channel === 'lifestyle';
const channelLabels: Record<string, string> = {
  dispatch: 'Dispatch', gear: 'Gear', table: 'The Table',
  chow: 'The Kitchen', transit: 'Travel', coord: 'Travel',
  lifestyle: 'Lifestyle',
};
const channelLabel = channelLabels[channel] ?? channel;
const channelHref = isDispatch ? '/dispatch' : isLifestyle ? '/lifestyle' : '/reviews';
// Use first gallery image as hero for reviews if no standalone image
const heroImage = image ?? (gallery && gallery.length > 0 ? gallery[0].image : undefined);
const remainingGallery = image
  ? gallery
  : gallery && gallery.length > 1 ? gallery.slice(1) : undefined;
// Channel-specific stamp labels
const stampLabels: Record<string, { top: string; bottom: string }> = {
  gear:    { top: 'FIELD TESTED', bottom: 'VERIFIED' },
  table:   { top: 'DINE TESTED',  bottom: 'VERIFIED' },
  chow:    { top: 'KITCHEN TESTED', bottom: 'VERIFIED' },
  transit: { top: 'ROAD TESTED',  bottom: 'VERIFIED' },
  coord:   { top: 'STAY TESTED',  bottom: 'VERIFIED' },
};
const stamp = stampLabels[channel] ?? { top: 'FIELD TESTED', bottom: 'VERIFIED' };
// Convert numeric rating value to star display
const ratingNum = rating ? parseInt(rating, 10) : 0;
const ratingStars = ratingNum > 0
  ? '★'.repeat(ratingNum) + '☆'.repeat(5 - ratingNum)
  : '';
const ratingDisplay = ratingNum > 0 ? `${ratingStars} ${ratingNum}/5` : '';
// Permalink for u-url (Bridgy Fed requires absolute self-link)
const permalink = Astro.url.href;
// Always produce an absolute URL for og:image (Mastodon/X/Bridgy Fed require absolute URLs)
const ogImageAbsolute = heroImage
  ? (heroImage.startsWith('http') ? heroImage : 'https://v64otd.com' + heroImage)
  : 'https://v64otd.com/images/FTW_interchange.jpg';
---
<BaseLayout
  title={title}
  description={description}
  ogImage={ogImageAbsolute}
  isArticle={true}
>
  <article class={'post-article h-entry channel-' + channel}>
    <!-- Article image for Bridgy Fed/Mastodon syndication -->
    {heroImage && (
      <img
        class="u-photo"
        src={heroImage.startsWith('http') ? heroImage : 'https://v64otd.com' + heroImage}
        alt={title}
        style="display:none"
      />
    )}
    <!-- Breadcrumb -->
    <nav class="post-breadcrumb" aria-label="breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <a href={channelHref}>{isDispatch ? 'Dispatch' : isLifestyle ? 'Lifestyle' : 'Reviews'}</a>
      {!isDispatch && !isLifestyle && (
        <>
          <span aria-hidden="true">›</span>
          <a href={'/' + channel}>{channelLabel}</a>
        </>
      )}
    </nav>
    <!-- Post Header -->
    <header class="post-header">
      <h1 class="post-title p-name">{title}</h1>
      {isDispatch && (
        <div class="dispatch-meta">
          {formattedDate && <time class="post-date dt-published" datetime={date}>{formattedDate}</time>}
          <div class="case-file-stamp" aria-label="Case File V64OTD">
            <svg viewBox="0 0 90 90" width="72" height="72" aria-hidden="true">
              <circle cx="45" cy="45" r="42" fill="none" stroke="var(--clay)" stroke-width="2.5"/>
              <circle cx="45" cy="45" r="36" fill="none" stroke="var(--clay)" stroke-width="1"/>
              <text x="45" y="34" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="7.5" fill="var(--clay)" letter-spacing="2">CASE FILE</text>
              <text x="45" y="50" text-anchor="middle" font-family="'Fraunces',serif" font-size="11" font-weight="700" fill="var(--clay)">V64OTD</text>
              <text x="45" y="63" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="6.5" fill="var(--clay)" letter-spacing="1.5">VERIFIED</text>
            </svg>
          </div>
        </div>
      )}
      {(isReview || isLifestyle) && formattedDate && <time class="post-date dt-published" datetime={date}>{formattedDate}</time>}
    </header>
    <!-- Review: Stacked gallery (1–4 photos) -->
    {isReview && gallery && gallery.length > 0 && gallery.length < 5 && (
      <div class="review-gallery">
        {gallery.map((item, index) => (
          <div class="review-image-wrap">
            <img src={item.image} alt={item.caption ?? title} class="review-hero-img" loading={index === 0 ? 'eager' : 'lazy'} />
            <div class="field-tested-stamp" aria-label={`${stamp.top} V64OTD`}>
              <svg viewBox="0 0 90 90" width="80" height="80" aria-hidden="true">
                <circle cx="45" cy="45" r="42" fill="rgba(239,233,220,0.92)" stroke="var(--cedar)" stroke-width="2.5"/>
                <circle cx="45" cy="45" r="36" fill="none" stroke="var(--cedar)" stroke-width="1"/>
                <text x="45" y="33" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="7" fill="var(--cedar)" letter-spacing="1.5">{stamp.top}</text>
                <text x="45" y="50" text-anchor="middle" font-family="'Fraunces',serif" font-size="11" font-weight="700" fill="var(--cedar)">V64OTD</text>
                <text x="45" y="63" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="6.5" fill="var(--cedar)" letter-spacing="1.5">{stamp.bottom}</text>
              </svg>
            </div>
            {item.caption && <figcaption class="gallery-caption">{item.caption}</figcaption>}
          </div>
        ))}
      </div>
    )}
    <!-- Review: Thumbnail grid + lightbox (5+ photos) -->
    {isReview && gallery && gallery.length >= 5 && (
      <>
        <p class="gallery-count-label">{gallery.length} PHOTOS — tap to enlarge</p>
          <div class="review-thumb-grid">
            {gallery.map((item, index) => (
              <button class="thumb-btn" data-index={String(index)} type="button" aria-label={item.caption || `Photo ${index + 1} of ${gallery.length}`}>
                <div class="thumb-wrap">
                  <img src={item.image} alt={item.caption ?? title} class="thumb-img" loading={index < 6 ? 'eager' : 'lazy'} />
                  <div class="thumb-stamp" aria-hidden="true">
                    <svg viewBox="0 0 90 90" width="44" height="44">
                      <circle cx="45" cy="45" r="42" fill="rgba(239,233,220,0.9)" stroke="var(--cedar)" stroke-width="2.5"/>
                      <circle cx="45" cy="45" r="36" fill="none" stroke="var(--cedar)" stroke-width="1"/>
                      <text x="45" y="33" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="7" fill="var(--cedar)" letter-spacing="1.5">{stamp.top}</text>
                      <text x="45" y="50" text-anchor="middle" font-family="'Fraunces',serif" font-size="11" font-weight="700" fill="var(--cedar)">V64OTD</text>
                      <text x="45" y="63" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="6.5" fill="var(--cedar)" letter-spacing="1.5">{stamp.bottom}</text>
                    </svg>
                  </div>
                </div>
                {item.caption && <span class="thumb-caption">{item.caption}</span>}
              </button>
            ))}
          </div>
          <!-- Lightbox -->
          <div id="review-lightbox" class="lightbox" hidden role="dialog" aria-modal="true" aria-label="Photo viewer">
            <button class="lb-close" id="lb-close" aria-label="Close">✕</button>
            <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous photo">&#8249;</button>
            <div class="lb-content">
              <div class="review-image-wrap lb-image-wrap">
                <img id="lb-img" src="" alt="" class="lb-img" />
                <div class="field-tested-stamp" aria-hidden="true">
                  <svg viewBox="0 0 90 90" width="80" height="80">
                    <circle cx="45" cy="45" r="42" fill="rgba(239,233,220,0.92)" stroke="var(--cedar)" stroke-width="2.5"/>
                    <circle cx="45" cy="45" r="36" fill="none" stroke="var(--cedar)" stroke-width="1"/>
                    <text x="45" y="33" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="7" fill="var(--cedar)" letter-spacing="1.5">{stamp.top}</text>
                    <text x="45" y="50" text-anchor="middle" font-family="'Fraunces',serif" font-size="11" font-weight="700" fill="var(--cedar)">V64OTD</text>
                    <text x="45" y="63" text-anchor="middle" font-family="'IBM Plex Mono',monospace" font-size="6.5" fill="var(--cedar)" letter-spacing="1.5">{stamp.bottom}</text>
                  </svg>
                </div>
              </div>
              <div class="lb-meta">
                <span class="lb-caption" id="lb-caption"></span>
                <span class="lb-counter" id="lb-counter"></span>
              </div>
            </div>
            <button class="lb-nav lb-next" id="lb-next" aria-label="Next photo">&#8250;</button>
          </div>
          <script id="gallery-json" type="application/json" set:html={JSON.stringify(gallery.map(g => ({ src: g.image, caption: g.caption ?? '' })))} />
        </>
    )}
    <!-- Lifestyle: gallery (all images, no stamp) -->
    {isLifestyle && gallery && gallery.length > 0 && (
      <div class="post-gallery">
        {gallery.map(item => (
          <figure class="gallery-figure">
            <img src={item.image} alt={item.caption ?? title} loading="lazy" class="gallery-img" />
            {item.caption && <figcaption class="gallery-caption">{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
    <!-- Dispatch: gallery (all images, no stamp) -->
    {isDispatch && gallery && gallery.length > 0 && (
      <div class="post-gallery">
        {gallery.map(item => (
          <figure class="gallery-figure">
            <img src={item.image} alt={item.caption ?? title} loading="lazy" class="gallery-img" />
            {item.caption && <figcaption class="gallery-caption">{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}
    <!-- Review: Verdict Box -->
    {isReview && (rating || cost) && (
      <div class="verdict-box">
        {ratingDisplay && <div class="verdict-item"><span class="verdict-label">RATING</span><span class="verdict-value rating-value">{ratingDisplay}</span></div>}
        {cost && <div class="verdict-item"><span class="verdict-label">COST</span><span class="verdict-value">{cost}</span></div>}
      </div>
    )}
    <!-- Review: Details (What You Ordered, Service, Ambiance, Best For, Would Return) -->
    {isReview && (foodType || whatYouOrdered || serviceQuality || ambiance || bestFor || wouldReturn) && (
      <div class="review-details">
        {foodType && (
          <div class="detail-row"><span class="detail-label">FOOD TYPE</span><p class="detail-text">{foodType}</p></div>
        )}
        {whatYouOrdered && (
          <div class="detail-row"><span class="detail-label">WHAT WE ORDERED</span><p class="detail-text">{whatYouOrdered}</p></div>
        )}
        {serviceQuality && (
          <div class="detail-row"><span class="detail-label">SERVICE</span><p class="detail-text">{serviceQuality}</p></div>
        )}
        {ambiance && (
          <div class="detail-row"><span class="detail-label">AMBIANCE</span><p class="detail-text">{ambiance}</p></div>
        )}
        {bestFor && (
          <div class="detail-row"><span class="detail-label">BEST FOR</span><p class="detail-text">{bestFor}</p></div>
        )}
        {wouldReturn && (
          <div class="detail-row">
            <span class="detail-label">WOULD RETURN?</span>
            <p class="detail-text detail-return">{wouldReturn === 'yes' ? 'Yes' : wouldReturn === 'no' ? 'No' : wouldReturn}</p>
          </div>
        )}
      </div>
    )}
    <!-- Dispatch tagline -->
    {isDispatch && (
      <p class="dispatch-tagline">Add v64otd.com to your daily reading list — the ledger doesn't lie.</p>
    )}
    <!-- Article Body -->
    <div class="post-body e-content prose"><slot /></div>
    <!-- Dispatch: Call to Action block -->
    {isDispatch && callToAction && callToAction.length > 0 && (
      <div class="cta-block">
        <p class="cta-label">CALL TO ACTION</p>
        <ol class="cta-list">{callToAction.map(item => <li>{item}</li>)}</ol>
      </div>
    )}
    <!-- Dispatch: Signoff -->
    {isDispatch && (
      <p class="dispatch-signoff">V64OTD // THE FILE GETS CLOSED. THE DAMAGE DOESN'T.</p>
    )}
    <!-- Lifestyle: Signoff -->
    {isLifestyle && signoff && (
      <p class="dispatch-signoff">{signoff}</p>
    )}
    <!-- Lifestyle: Affiliate CTA -->
    {isLifestyle && affiliateLinks && affiliateLinks.length > 0 && (
      <div class="affiliate-block">
        <p class="affiliate-label">MENTIONED IN THIS POST</p>
        <div class="affiliate-links">
          {affiliateLinks.map(link => (
            <a href={link.url} class="affiliate-btn" target="_blank" rel="noopener sponsored">{link.label}</a>
          ))}
        </div>
        <p class="affiliate-disclosure">Affiliate disclosure: links above may earn a small commission at no cost to you.</p>
      </div>
    )}
    <!-- Review: Affiliate CTA -->
    {isReview && affiliateLinks && affiliateLinks.length > 0 && (
      <div class="affiliate-block">
        <p class="affiliate-label">WHERE TO GET IT</p>
        <div class="affiliate-links">
          {affiliateLinks.map(link => (
            <a href={link.url} class="affiliate-btn" target="_blank" rel="noopener sponsored">{link.label}</a>
          ))}
        </div>
        <p class="affiliate-disclosure">Affiliate disclosure: links above may earn a small commission at no cost to you. OTD only links products personally tested and recommended.</p>
      </div>
    )}
    <!-- Tags -->
    {tagList.length > 0 && (
      <div class="post-tags">
        {tagList.map(tag => <a href={'/tags/' + tag.toLowerCase()} class="tag-chip">#{tag}</a>)}
      </div>
    )}
    <!-- Bridgy Fed microformat hooks -->
    <a href={permalink} class="u-url" hidden></a>
    <a class="u-bridgy-fed" href="https://fed.brid.gy/" hidden="from-humans"></a>
  </article>
</BaseLayout>
<style>
  .post-article { max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .post-breadcrumb {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem; letter-spacing: 0.06em;
    color: rgba(43,37,32,0.55); margin-bottom: 1.75rem;
    display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;
  }
  .post-breadcrumb a { color: rgba(43,37,32,0.55); text-decoration: none; }
  .post-breadcrumb a:hover { color: var(--clay); }
  .post-header { margin-bottom: 1.5rem; }
  .post-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.8rem, 5vw, 2.8rem);
    font-weight: 700; line-height: 1.15; color: var(--ink); margin: 0 0 1rem;
  }
  .post-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem; letter-spacing: 0.08em;
    color: rgba(43,37,32,0.5); text-transform: uppercase; display: block; margin-bottom: 0.75rem;
  }
  .dispatch-meta { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .case-file-stamp { flex-shrink: 0; opacity: 0.85; }
  /* Stacked gallery (1–4 photos) */
  .review-gallery { display: flex; flex-direction: column; gap: 1.5rem; margin: 0 0 1.5rem; }
  .review-image-wrap { position: relative; border-radius: 3px; overflow: hidden; }
  .review-hero-img { display: block; width: 100%; height: auto; max-height: 420px; object-fit: cover; }
  .field-tested-stamp { position: absolute; bottom: 1rem; right: 1rem; filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3)); }
  /* Thumbnail grid (5+ photos) */
  .gallery-count-label {
    font-family: 'IBM Plex Mono', monospace; font-size: 0.66rem;
    letter-spacing: 0.12em; color: rgba(43,37,32,0.4);
    text-transform: uppercase; margin: 0 0 0.6rem;
  }
  .review-thumb-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
    margin: 0 0 1.5rem;
  }
  .thumb-btn {
    background: none; border: none; padding: 0; cursor: pointer;
    display: flex; flex-direction: column; gap: 0.2rem;
    border-radius: 3px; overflow: visible;
  }
  .thumb-wrap {
    position: relative; aspect-ratio: 4/3;
    overflow: hidden; border-radius: 3px;
  }
  .thumb-img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.2s; display: block;
  }
  .thumb-btn:hover .thumb-img { transform: scale(1.05); }
  .thumb-stamp {
    position: absolute; bottom: 0.3rem; right: 0.3rem;
    filter: drop-shadow(0 1px 3px rgba(0,0,0,0.4));
    pointer-events: none;
  }
  .thumb-caption {
    font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem;
    color: rgba(43,37,32,0.45); letter-spacing: 0.03em;
    display: block; text-align: left; padding: 0 0.1rem;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  /* Lightbox */
  .lightbox {
    position: fixed; inset: 0; z-index: 1000;
    background: rgba(20,16,12,0.95);
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    padding: 1rem;
  }
  .lightbox[hidden] { display: none; }
  .lb-content {
    display: flex; flex-direction: column; align-items: center;
    max-width: min(800px, calc(100vw - 8rem)); width: 100%;
  }
  .lb-image-wrap { width: 100%; }
  .lb-img {
    max-width: 100%; max-height: 75vh; object-fit: contain;
    border-radius: 3px; display: block; margin: 0 auto;
  }
  .lb-meta {
    display: flex; justify-content: space-between; align-items: center;
    width: 100%; margin-top: 0.75rem; gap: 1rem;
  }
  .lb-caption {
    font-family: 'Inter', sans-serif; font-size: 0.88rem;
    color: rgba(239,233,220,0.7); flex: 1;
  }
  .lb-counter {
    font-family: 'IBM Plex Mono', monospace; font-size: 0.7rem;
    color: rgba(239,233,220,0.35); letter-spacing: 0.1em; white-space: nowrap;
  }
  .lb-close {
    position: absolute; top: 1rem; right: 1rem;
    background: none; border: none;
    color: rgba(239,233,220,0.6); font-size: 1.4rem;
    cursor: pointer; padding: 0.25rem; line-height: 1;
    transition: color 0.15s;
  }
  .lb-close:hover { color: #fff; }
  .lb-nav {
    background: none; border: none;
    color: rgba(239,233,220,0.5); font-size: 3.5rem; line-height: 1;
    cursor: pointer; padding: 0.5rem; flex-shrink: 0;
    transition: color 0.15s; user-select: none;
  }
  .lb-nav:hover { color: #fff; }
  .post-gallery { margin: 0 0 2rem; display: flex; flex-direction: column; gap: 1rem; }
  .gallery-figure { margin: 0; }
  .gallery-img { width: 100%; height: auto; border-radius: 3px; display: block; max-height: 480px; object-fit: cover; }
  .gallery-caption { font-family: 'IBM Plex Mono', monospace; font-size: 0.7rem; letter-spacing: 0.04em; color: rgba(43,37,32,0.5); margin-top: 0.4rem; }
  .verdict-box {
    display: flex; gap: 2rem; background: var(--card-bg);
    border: 1.5px solid var(--border); border-radius: 3px;
    padding: 1rem 1.5rem; margin-bottom: 1.75rem; flex-wrap: wrap;
  }
  .verdict-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .verdict-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; letter-spacing: 0.12em; color: rgba(43,37,32,0.5); text-transform: uppercase; }
  .verdict-value { font-family: 'Fraunces', serif; font-size: 1.3rem; font-weight: 600; color: var(--ochre); }
  .rating-value { font-family: 'IBM Plex Mono', monospace; font-size: 1rem; letter-spacing: 0.04em; }
  .review-details {
    display: flex; flex-direction: column; gap: 1rem;
    background: var(--card-bg); border: 1.5px solid var(--border); border-radius: 3px;
    padding: 1.25rem 1.5rem; margin-bottom: 1.75rem;
  }
  .detail-row { display: flex; flex-direction: column; gap: 0.25rem; }
  .detail-label {
    font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem;
    letter-spacing: 0.12em; color: rgba(43,37,32,0.5); text-transform: uppercase;
  }
  .detail-text {
    font-family: 'Inter', sans-serif; font-size: 0.95rem; line-height: 1.55;
    color: var(--ink); margin: 0;
  }
  .detail-return { font-weight: 600; }
  .dispatch-tagline {
    font-family: 'Inter', sans-serif; font-size: 0.88rem;
    color: rgba(43,37,32,0.5); font-style: italic; margin: 0 0 2rem;
    border-left: 3px solid var(--clay); padding-left: 0.85rem;
  }
  .post-body { font-family: 'Inter', sans-serif; font-size: 1.05rem; line-height: 1.75; color: var(--ink); margin-bottom: 2.5rem; }
  .post-body :global(h2) { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 600; margin: 2rem 0 0.75rem; color: var(--ink); }
  .post-body :global(h3) { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: var(--ink); }
  .post-body :global(p) { margin: 0 0 1.25em; }
  .post-body :global(a) { color: var(--clay); text-underline-offset: 3px; }
  .post-body :global(blockquote) { border-left: 3px solid var(--clay); margin: 1.5rem 0; padding: 0.5rem 1rem; color: rgba(43,37,32,0.7); font-style: italic; }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 1.5rem; margin: 0 0 1.25em; }
  .post-body :global(li) { margin-bottom: 0.4em; }
  .post-body :global(code) { font-family: 'IBM Plex Mono', monospace; font-size: 0.88em; background: rgba(43,37,32,0.07); padding: 0.1em 0.3em; border-radius: 2px; }
  .post-body :global(img) { max-width: 100%; height: auto; border-radius: 3px; margin: 1.5rem 0; display: block; }
  .cta-block {
    background: var(--card-bg); border: 1.5px solid var(--border);
    border-left: 4px solid var(--clay); border-radius: 3px;
    padding: 1.25rem 1.5rem; margin: 0 0 2rem;
  }
