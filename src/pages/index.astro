---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
export const prerender = true;
const allDispatch = await getCollection('dispatch');
const posts = allDispatch
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
  .slice(0, 5);
---
<BaseLayout title="OTD Vault — The Ledger Doesn't Lie" description="Old Texas Dude. Dispatch from the margins. Field-tested reviews.">

  <!-- Bridgy Fed federation link -->
  <a rel="me" href="https://web.brid.gy/r/https://v64otd.com/" hidden></a>

  <!-- Bridgy Fed / Mastodon h-card -->
  <span class="h-card" hidden>
    <a class="u-url" rel="me" href="https://v64otd.com/">OTD Vault</a>
    <img class="u-photo" src="https://v64otd.com/images/profile/v64otd-mastodon-avatar.jpg" alt="Old Texas Dude" />
    <img class="u-featured" src="https://v64otd.com/images/FTW_interchange.jpg" alt="Fort Worth interchange at dusk" />
  </span>

  <!-- Hero -->
  <section class="dispatch-hero">
    <div class="hero-inner">
      <p class="hero-eyebrow">OLD TEXAS DUDE // INDEPENDENT DISPATCH</p>
      <h1 class="hero-title">The ledger doesn't lie.</h1>
      <p class="hero-sub">Plain-spoken coverage of money, power, and the people who take your tax dollars. No affiliate links. No agenda but the truth.</p>
    </div>
  </section>

  <!-- Dispatch Feed -->
  <section class="dispatch-feed">
    <div class="feed-header">
      <h2 class="feed-label">RECENT DISPATCHES</h2>
    </div>
    <div class="feed-list h-feed">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          href={`/dispatch/${post.id}`}
          channel="dispatch"
          layout="feed"
        />
      ))}
    </div>
    <div class="feed-footer">
      <a href="/dispatch" class="btn-outline">Full dispatch archive →</a>
    </div>
  </section>

  <!-- Email Signup -->
  <section class="signup-block">
    <div class="signup-inner">
      <p class="signup-eyebrow">THE LEDGER</p>
      <h2 class="signup-title">Add v64otd.com to your daily reading list.</h2>
      <p class="signup-sub">The file gets closed. The damage doesn't. Get new dispatches in your inbox.</p>
      <form class="signup-form" id="signup-form">
        <input type="email" name="email" placeholder="your@email.com" required class="signup-input" />
        <button type="submit" class="btn-primary" id="signup-btn">Subscribe</button>
      </form>
      <p class="signup-note" id="signup-note">One list. No spam. Unsubscribe any time.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .dispatch-hero {
    position: relative;
    background-image: url('/images/FTW_interchange.jpg');
    background-size: cover;
    background-position: center 40%;
    color: var(--bg-limestone);
    padding: 6rem 1.5rem 5rem;
    text-align: center;
  }
  .dispatch-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20,16,12,0.72) 0%,
      rgba(20,16,12,0.58) 60%,
      rgba(20,16,12,0.78) 100%
    );
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
  }
  .hero-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--ochre);
    margin: 0 0 1rem;
    text-transform: uppercase;
  }
  .hero-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 1rem;
    color: var(--bg-limestone);
  }
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(239,233,220,0.8);
    margin: 0;
    max-width: 540px;
    margin-inline: auto;
  }

  /* Feed */
  .dispatch-feed {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }
  .feed-header {
    border-bottom: 2px solid var(--ink);
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
  }
  .feed-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--ink);
    margin: 0;
  }
  .feed-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .feed-footer {
    margin-top: 2.5rem;
    text-align: center;
  }
  .btn-outline {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: var(--clay);
    text-decoration: none;
    border: 1.5px solid var(--clay);
    padding: 0.5rem 1.25rem;
    border-radius: 2px;
    transition: background 0.15s, color 0.15s;
  }
  .btn-outline:hover {
    background: var(--clay);
    color: #fff;
  }

  /* Signup */
  .signup-block {
    background: var(--card-bg);
    border-top: 2px solid var(--border);
    border-bottom: 2px solid var(--border);
    padding: 3.5rem 1.5rem;
    text-align: center;
  }
  .signup-inner {
    max-width: 520px;
    margin: 0 auto;
  }
  .signup-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--cedar);
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }
  .signup-title {
    font-family: 'Fraunces', serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }
  .signup-sub {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: rgba(43,37,32,0.7);
    margin: 0 0 1.75rem;
    line-height: 1.6;
  }
  .signup-form {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .signup-input {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    padding: 0.65rem 1rem;
    border: 1.5px solid var(--border);
    border-radius: 2px;
    background: #fff;
    color: var(--ink);
    flex: 1;
    min-width: 220px;
    max-width: 300px;
  }
  .signup-input:focus {
    outline: 2px solid var(--clay);
    border-color: transparent;
  }
  .btn-primary {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    background: var(--clay);
    color: #fff;
    border: none;
    padding: 0.65rem 1.25rem;
    border-radius: 2px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.88; }
  .signup-note {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: rgba(43,37,32,0.5);
    margin: 1rem 0 0;
  }
  .signup-note.success { color: var(--cedar); }
  .signup-note.error   { color: var(--clay);  }
</style>

<script>
  const form = document.getElementById('signup-form') as HTMLFormElement;
  const btn  = document.getElementById('signup-btn')  as HTMLButtonElement;
  const note = document.getElementById('signup-note') as HTMLParagraphElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Subscribing...';
    const email = (form.elements.namedItem('email') as HTMLInputElement).value;
    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (res.ok) {
        note.textContent = "You're on the list. The ledger awaits.";
        note.className = 'signup-note success';
        form.reset();
      } else {
        note.textContent = 'Something went wrong. Please try again.';
        note.className = 'signup-note error';
      }
    } catch {
      note.textContent = 'Network error. Please try again.';
      note.className = 'signup-note error';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Subscribe';
    }
  });
</script>
