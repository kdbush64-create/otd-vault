---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const allDispatch = await getCollection('dispatch');
const dispatchPosts = [...allDispatch]
  .sort((a, b) => String(b.data.date ?? '').localeCompare(String(a.data.date ?? '')))
  .map(post => ({
    title: post.data.title,
    date: String(post.data.date ?? ''),
    description: post.data.description ?? '',
    slug: post.slug,
  }));
---
<BaseLayout title="OTD Vault | The Watch Tower" description="Vintage64TX — Dispatch, Transit, Gear, Coord, Table." showHero={true}>
<span class="h-card" hidden>
  <a class="u-url" rel="me" href="https://v64otd.com/">OTD Vault | The Watch Tower</a>
  <img class="u-photo" src="https://v64otd.com/images/profile/v64otd-mastodon-avatar.jpg" />
  <img class="u-featured" src="https://v64otd.com/images/profile/v64otd-mastodon-header.jpg" />
</span>  
<nav class="vault-nav-container">
    <div class="primary-nav" style="margin-bottom: 15px; width: 100%;">
      <a href="/about" class="submit-btn" style="display:block; width:100%; padding:12px; border-color:var(--accent); color:var(--accent); font-weight:bold; font-size:1rem; text-align:center; text-decoration:none; box-sizing:border-box;">
        ABOUT: OLD TEXAS DUDE
      </a>
    </div>
    <div class="secondary-filters">
      <a href="/dispatch" class="submit-btn" style="text-decoration:none;">DISPATCH ARCHIVES</a>
      <a href="/transit" class="submit-btn" style="text-decoration:none;">TRANSIT</a>
      <a href="/gear" class="submit-btn" style="text-decoration:none;">GEAR</a>
      <a href="/coord" class="submit-btn" style="text-decoration:none;">COORD</a>
      <a href="/table" class="submit-btn" style="text-decoration:none;">THE TABLE</a>
      <a href="/chow" class="submit-btn" style="text-decoration:none;">THE KITCHEN</a>
      <a href="/substack" class="submit-btn" style="text-decoration:none;">SUBSTACK FEED</a>
    </div>
    <p class="instruction-text" style="text-align:center; margin-top: 14px; margin-bottom: 0;">
      SELECT A DATA_CHANNEL OR SCAN FOR UPDATES.
    </p>
  </nav>
  <div class="vault-layout">
    <section class="log-display">
      <article id="content" class="blog-post">
        <div style="text-align: center; padding: 30px 20px 10px;">
          <h2 class="force-blue" style="letter-spacing: 2px;">&gt; SYSTEM_READY</h2>
          <p class="blink" style="font-size: 0.85rem; color: #00d4ff; text-shadow: 0 0 8px rgba(0, 212, 255, 0.6); margin-bottom: 20px; font-family: monospace;">
            [ INITIALIZING_DATA_STREAM... ]
          </p>
        </div>
        <div style="padding: 0 20px 40px;">
          <p style="color: var(--secondary); font-size: 0.78rem; letter-spacing: 2px; margin-bottom: 14px; font-family: monospace;">
            &gt; DAILY_DISPATCH
          </p>
          <div id="daily-dispatch-list">
            <p style="color: var(--primary-dim); font-size: 0.82rem;">[ LOADING... ]</p>
          </div>
        </div>
      </article>
    </section>
  </div>
  <script define:vars={{ dispatchPosts }}>
    (function () {
      function nthSundayOf(year, month, n) {
        const first = new Date(year, month - 1, 1);
        return new Date(year, month - 1, 1 + (7 - first.getDay()) % 7 + (n - 1) * 7);
      }
      function isInCDT(datePart) {
        const [y, m, d] = datePart.split('-').map(Number);
        const date = new Date(y, m - 1, d);
        return date >= nthSundayOf(y, 3, 2) && date < nthSundayOf(y, 11, 1);
      }
      function formatTime(dateStr) {
        if (!dateStr || !dateStr.includes('T')) return null;
        try {
          const clean = dateStr.split('.')[0].replace('Z', '');
          const [hourStr, minuteStr] = clean.split('T')[1].split(':');
          const hour = parseInt(hourStr, 10);
          const minute = parseInt(minuteStr, 10);
          const datePart = clean.split('T')[0];
          const hour12 = hour % 12 || 12;
          const ampm = hour >= 12 ? 'PM' : 'AM';
          const tz = isInCDT(datePart) ? 'CDT' : 'CST';
          return String(hour12).padStart(2,'0') + ':' + String(minute).padStart(2,'0') + ampm + '-' + tz;
        } catch (e) { return null; }
      }
      function renderStars(avg) {
        if (avg === null) return '☆☆☆☆☆';
        const full = Math.round(avg);
        return '★'.repeat(full) + '☆'.repeat(5 - full);
      }

      const now = new Date();
      const today = now.getFullYear() + '-' +
        String(now.getMonth() + 1).padStart(2, '0') + '-' +
        String(now.getDate()).padStart(2, '0');
      const [ty, tm, td] = today.split('-').map(Number);
      const co = new Date(ty, tm - 1, td - 2);
      const cutoff = co.getFullYear() + '-' +
        String(co.getMonth() + 1).padStart(2, '0') + '-' +
        String(co.getDate()).padStart(2, '0');

      const recent = dispatchPosts.filter(p => p.date.split('T')[0] >= cutoff);
      const container = document.getElementById('daily-dispatch-list');
      if (!container) return;

      if (recent.length === 0) {
        container.innerHTML = '<p style="color:var(--primary-dim);font-size:0.82rem;">[ NO DISPATCHES IN THE LAST 2 DAYS ]</p>';
        return;
      }

      // Render cards first, with a placeholder for ratings
      container.innerHTML = recent.map(post => {
        const datePart = post.date.split('T')[0];
        const time = formatTime(post.date);
        const dateDisplay = new Date(datePart + 'T00:00:00').toLocaleDateString('en-US', {
          year: 'numeric', month: 'long', day: 'numeric'
        });
        const timeSpan = time ? ' <span style="margin-left:8px;opacity:0.75;">' + time + '</span>' : '';
        const desc = post.description
          ? '<p style="color:var(--primary-dim);font-size:0.82rem;margin-top:4px;line-height:1.4;">' + post.description + '</p>'
          : '';
        return '<div style="border-bottom:1px dashed var(--border);padding:10px 0;margin-bottom:4px;">' +
          '<a href="/dispatch/' + post.slug + '/" style="color:var(--accent);" class="log-link">&gt; ' + post.title + '</a>' +
          '<p style="color:var(--primary-dim);font-size:0.75rem;margin-top:2px;">' + dateDisplay + timeSpan + '</p>' +
          '<div id="rating-' + post.slug + '" style="font-size:0.82rem;color:var(--primary-dim);margin:2px 0 4px;"></div>' +
          desc +
          '</div>';
      }).join('');

      // Fetch ratings for each card and inject
      recent.forEach(post => {
        const ratingEl = document.getElementById('rating-' + post.slug);
        if (!ratingEl) return;
        fetch('/api/rate?slug=dispatch/' + post.slug)
          .then(r => r.json())
          .then(data => {
            if (data.count > 0) {
              ratingEl.innerHTML =
                '<span style="color:#f0c040;letter-spacing:2px;">' + renderStars(data.average) + '</span>' +
                ' <span>' + data.average.toFixed(1) + '</span>' +
                ' <span style="opacity:0.7;">(' + data.count + ' ' + (data.count === 1 ? 'rating' : 'ratings') + ')</span>';
            } else {
              ratingEl.innerHTML = '<span style="opacity:0.5;">No ratings yet <span style="color:#888;">☆☆☆☆☆</span></span>';
            }
          })
          .catch(() => {});
      });
    })();
  </script>
<a rel="me" href="https://web.brid.gy/r/https://v64otd.com/" hidden></a>
</BaseLayout>
</BaseLayout>
