---
import { getCollection, getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export const prerender = true;

const REVIEW_CHANNELS = ['gear', 'table', 'chow', 'transit', 'coord'] as const;
const DISPATCH_CHANNELS = ['dispatch'] as const;
const ALL_CHANNELS = [...DISPATCH_CHANNELS, ...REVIEW_CHANNELS] as const;

type Channel = typeof ALL_CHANNELS[number];

export async function getStaticPaths() {
  const paths = [];
  for (const channel of ALL_CHANNELS) {
    const entries = await getCollection(channel as any);
    for (const entry of entries) {
      paths.push({
        params: { channel, slug: entry.id },
        props: { entry, channel },
      });
    }
  }
  return paths;
}

const { channel, entry } = Astro.props as { channel: Channel; entry: any };
const { Content } = await render(entry);

const data = entry.data;

// Extract common fields
const title = data.title;
const date = data.date;
const description = data.description;
const tags = 'tags' in data ? data.tags : undefined;
const image = 'image' in data ? data.image : undefined;

// Dispatch-only fields
const callToAction = 'callToAction' in data ? data.callToAction : undefined;

// Review-only fields
const rating = 'rating' in data ? data.rating : undefined;
const cost = 'cost' in data ? data.cost : undefined;
const affiliateLinks = 'affiliateLinks' in data ? data.affiliateLinks : undefined;
---

<PostLayout
  title={title}
  date={date}
  description={description}
  tags={tags}
  channel={channel}
  image={image}
  callToAction={callToAction}
  rating={rating}
  cost={cost}
  affiliateLinks={affiliateLinks}
>
  <Content />
</PostLayout>
