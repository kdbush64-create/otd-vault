---
export const prerender = true;
import PostLayout from '../../layouts/PostLayout.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const paths = [];
  for (const channel of ['dispatch', 'transit', 'gear', 'coord', 'table', 'chow', 'xposts'] as const) {
    const posts = await getCollection(channel);
    for (const post of posts) {
      paths.push({ params: { channel, slug: post.slug }, props: { post, channel } });
    }
  }
  return paths;
}
const { post, channel } = Astro.props;
const { Content } = await post.render();
const rating   = 'rating'   in post.data ? post.data.rating   : undefined;
const cost     = 'cost'     in post.data ? post.data.cost     : undefined;
const foodType = 'foodType' in post.data ? post.data.foodType : undefined;
const address  = 'address'  in post.data ? post.data.address  : undefined;
const website  = 'website'  in post.data ? post.data.website  : undefined;
---
<PostLayout
  title={post.data.title}
  date={post.data.date}
  description={'description' in post.data ? post.data.description : undefined}
  channel={channel}
  rating={rating}
  cost={cost}
  foodType={foodType}
  address={address}
  website={website}
>
  <Content />
</PostLayout>
