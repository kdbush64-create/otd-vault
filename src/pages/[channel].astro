---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

export const prerender = true;

type Channel = 'dispatch' | 'gear' | 'table' | 'chow' | 'transit' | 'coord' | 'lifestyle';

export async function getStaticPaths() {
  const channels = ['dispatch', 'gear', 'table', 'chow', 'transit', 'coord', 'lifestyle'];
  return channels.map(channel => ({ params: { channel } }));
}

const { channel } = Astro.params as { channel: Channel };

const channelMeta: Record<Channel, { title: string; description: string; eyebrow: string }> = {
  dispatch: {
    title: 'Dispatch Archives — OTD Vault',
    description: 'Every dispatch. Plain-spoken coverage of money, power, and accountability.',
    eyebrow: 'INDEPENDENT DISPATCH',
  },
  gear: {
    title: 'Gear Reviews — OTD Vault',
    description: 'Field-tested gear reviews. Tools, tech, and outdoor kit.',
    eyebrow: 'GEAR REVIEWS',
  },
  table: {
    title: 'The Table — OTD Vault',
    description: 'Restaurant reviews from Texas and beyond.',
    eyebrow: 'RESTAURANT REVIEWS',
  },
  chow: {
    title: 'The Kitchen — OTD Vault',
    description: 'Recipes, techniques, and kitchen picks.',
    eyebrow: 'KITCHEN & RECIPES',
  },
  transit: {
    title: 'Travel — OTD Vault',
    description: 'Road dispatches, local color, and travel writing.',
    eyebrow: 'TRAVEL WRITING',
  },
  coord: {
    title: 'Getaways — OTD Vault',
    description: 'Weekend getaways and lodging reviews.',
    eyebrow: 'GETAWAYS & LODGING',
  },
  lifestyle: {
    title: 'Lifestyle — OTD Vault',
    description: 'Life off the clock. Health, travel, pets, and everything that isn\u2019t politics or a product review.',
    eyebrow: 'LIFESTYLE',
  },
};

const meta = channelMeta[channel];
const posts = (await getCollection(channel as any))
  .sort((a: any, b: any) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

const isDispatch = channel === 'dispatch';
const channelHeroImages: Partial<Record<Channel, string>> = {
  dispatch: '/images/archives-hero.jpg',
  lifestyle: '/images/lifestyle-hero.jpg',
};
const heroImage = channelHeroImages[channel];
---

<BaseLayout title={meta.title} description={meta.description}>

  <!-- Channel Header -->
  <section class={'channel-hero' + (heroImage ? ' has-photo' : '')} style={heroImage ? `--hero-img: url('${heroImage}')` : undefined}>
    <div class="hero-inner">
      <p class="hero-eyebrow">{meta.eyebrow}</p>
      <h1 class="hero-title">
        {channel === 'dispatch' ? 'Dispatch Archives' :
         channel === 'gear' ? 'Gear' :
         channel === 'table' ? 'The Table' :
         channel === 'chow' ? 'The Kitchen' :
         channel === 'transit' ? 'Travel' :
         channel === 'lifestyle' ? 'Lifestyle' :
         'Getaways'}
      </h1>
      {isDispatch && (
        <p class="hero-sub">Every dispatch. The file gets closed. The damage doesn't.</p>
      )}
    </div>
  </section>

  <!-- Posts -->
  <section class="posts-section">
    <div class={isDispatch ? 'feed-list' : 'card-grid'}>
      {posts.map((post: any) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          href={`/${channel}/${post.id.replace(/\.mdoc$/, '')}`}
          channel={channel}
          layout={isDispatch ? 'feed' : 'card'}
        />
      ))}
    </div>
    {posts.length === 0 && (
      <p class="empty-state">Nothing filed yet. Check back soon.</p>
    )}
  </section>

</BaseLayout>

<style>
  /* Hero */
  .channel-hero {
    position: relative;
    background: var(--ink);
    color: var(--bg-limestone);
    padding: 3rem 1.5rem 2.75rem;
    text-align: center;
  }
  .channel-hero.has-photo {
    background-image: var(--hero-img);
    background-size: cover;
    background-position: center 50%;
    padding: 5rem 1.5rem 4.5rem;
  }
  .channel-hero.has-photo::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(20,16,12,0.70) 0%,
      rgba(20,16,12,0.55) 55%,
      rgba(20,16,12,0.75) 100%
    );
  }
  .channel-hero.has-photo .hero-inner {
    position: relative;
    z-index: 1;
  }
  .hero-inner { max-width: 640px; margin: 0 auto; }
  .hero-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    color: var(--ochre);
    margin: 0 0 0.75rem;
    text-transform: uppercase;
  }
  .hero-title {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.9rem, 5vw, 2.8rem);
    font-weight: 700;
    color: var(--bg-limestone);
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }
  .hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    color: rgba(239,233,220,0.7);
    margin: 0;
  }

  /* Feed layout (dispatch) */
  .posts-section {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .feed-list {
    display: flex;
    flex-direction: column;
  }

  /* Card grid layout (reviews) */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  /* When grid is used, expand section width */
  .posts-section:has(.card-grid) {
    max-width: 960px;
  }

  .empty-state {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    color: rgba(43,37,32,0.45);
    text-align: center;
    padding: 3rem 0;
  }
</style>
