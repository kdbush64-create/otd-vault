---
export const prerender = false;

import ChannelLayout from '../layouts/ChannelLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

type Channel = 'dispatch' | 'transit' | 'gear' | 'coord' | 'table' | 'chow' | 'xposts';
const validChannels: Channel[] = ['dispatch', 'transit', 'gear', 'coord', 'table', 'chow', 'xposts'];

const { channel } = Astro.params;

if (!channel || !validChannels.includes(channel as Channel)) {
  return Astro.redirect('/');
}

const typedChannel = channel as Channel;

let allPosts: any[] = [];
try {
  allPosts = await getCollection(typedChannel);
} catch (e) {
  allPosts = [];
}

const posts = typedChannel === 'xposts'
  ? allPosts.filter((post: any) => post.data.approved === true)
  : allPosts;

const sortedPosts = [...posts].sort((a: any, b: any) => {
  const da = String(a.data.date ?? '');
  const db = String(b.data.date ?? '');
  return db.localeCompare(da);
});

// ── Dispatch helpers ─────────────────────────────────────────────────────────
function nthSundayOf(year: number, month: number, n: number): Date {
  const first = new Date(year, month - 1, 1);
  const daysUntilSunday = (7 - first.getDay()) % 7;
  return new Date(year, month - 1, 1 + daysUntilSunday + (n - 1) * 7);
}
function isInCDT(datePart: string): boolean {
  const [year, month, day] = datePart.split('-').map(Number);
  const d = new Date(year, month - 1, day);
  return d >= nthSundayOf(year, 3, 2) && d < nthSundayOf(year, 11, 1);
}
function formatDispatchTime(dateStr: string): string | null {
  if (!dateStr || !dateStr.includes('T')) return null;
  try {
    const [hourStr, minuteStr] = dateStr.split('T')[1].split(':');
    const hour = parseInt(hourStr, 10);
    const minute = parseInt(minuteStr, 10);
    const hour12 = hour % 12 || 12;
    const ampm = hour >= 12 ? 'PM' : 'AM';
    const tz = isInCDT(dateStr.split('T')[0]) ? 'CDT' : 'CST';
    return `${String(hour12).padStart(2,'0')}:${String(minute).padStart(2,'0')}${ampm}-${tz}`;
  } catch { return null; }
}
function getCentralToday(): string {
  const now = new Date();
  const y = now.getUTCFullYear(), m = now.getUTCMonth() + 1, d = now.getUTCDate();
  const utcStr = `${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  const offset = isInCDT(utcStr) ? -5 : -6;
  const central = new Date(now.getTime() + offset * 3600000);
  return central.toISOString().split('T')[0];
}

const isDispatch = typedChannel === 'dispatch';
const todayStr = getCentralToday();
const [ty, tm, td] = todayStr.split('-').map(Number);
const co = new Date(ty, tm - 1, td - 2);
const cutoffStr = `${co.getFullYear()}-${String(co.getMonth()+1).padStart(2,'0')}-${String(co.getDate()).padStart(2,'0')}`;

const dailyPosts  = isDispatch ? sortedPosts.filter((p: any) => String(p.data.date ?? '').split('T')[0] >= cutoffStr) : [];
const archivePosts = isDispatch ? sortedPosts.filter((p: any) => String(p.data.date ?? '').split('T')[0] < cutoffStr) : sortedPosts;
---

<ChannelLayout channel={typedChannel}>
  {isDispatch && (
    <div>
      <h2 style="font-size:0.8rem;color:var(--primary-dim);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">Daily Dispatches</h2>
      {dailyPosts.length === 0 && (
        <p style="color:var(--primary-dim);font-size:0.82rem;">No dispatches in the last 2 days.</p>
      )}
      {dailyPosts.map((post: any) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          time={formatDispatchTime(String(post.data.date ?? '')) ?? undefined}
          description={post.data.description}
          href={`/${typedChannel}/${post.slug}/`}
        />
      ))}
      {archivePosts.length > 0 && (
        <div style="margin-top:32px;">
          <h2 style="font-size:0.8rem;color:var(--primary-dim);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:12px;">Dispatch Archive</h2>
          {archivePosts.map((post: any) => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              time={formatDispatchTime(String(post.data.date ?? '')) ?? undefined}
              description={post.data.description}
              href={`/${typedChannel}/${post.slug}/`}
            />
          ))}
        </div>
      )}
    </div>
  )}
  {!isDispatch && (
    <div>
      {sortedPosts.map((post: any) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          href={`/${typedChannel}/${post.slug}/`}
        />
      ))}
    </div>
  )}
</ChannelLayout>
