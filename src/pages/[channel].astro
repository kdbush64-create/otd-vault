---
export const prerender = true;

import ChannelLayout from '../layouts/ChannelLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const channels = ['dispatch', 'transit', 'gear', 'coord', 'table', 'chow', 'xposts'] as const;
  return channels.map(channel => ({ params: { channel } }));
}

type Channel = 'dispatch' | 'transit' | 'gear' | 'coord' | 'table' | 'chow' | 'xposts';
const { channel } = Astro.params as { channel: Channel };

const allPosts = await getCollection(channel);
const posts = channel === 'xposts'
  ? allPosts.filter(post => post.data.approved === true)
  : allPosts;

const sortedPosts = [...posts].sort((a, b) =>
  String(b.data.date ?? '').localeCompare(String(a.data.date ?? ''))
);

function nthSundayOf(year: number, month: number, n: number): Date {
  const first = new Date(year, month - 1, 1);
  return new Date(year, month - 1, 1 + (7 - first.getDay()) % 7 + (n - 1) * 7);
}
function isInCDT(datePart: string): boolean {
  const [year, month, day] = datePart.split('-').map(Number);
  const d = new Date(year, month - 1, day);
  return d >= nthSundayOf(year, 3, 2) && d < nthSundayOf(year, 11, 1);
}
function formatDispatchTime(dateStr: string): string | null {
  if (!dateStr || !dateStr.includes('T')) return null;
  try {
    let hour, minute, datePart;

    if (dateStr.endsWith('Z') || dateStr.includes('+')) {
      // UTC ISO format from Keystatic — convert to Central time
      const d = new Date(dateStr);
      const utcY = d.getUTCFullYear();
      const utcM = String(d.getUTCMonth() + 1).padStart(2, '0');
      const utcD = String(d.getUTCDate()).padStart(2, '0');
      const utcDateStr = `${utcY}-${utcM}-${utcD}`;
      const offsetHours = isInCDT(utcDateStr) ? -5 : -6;
      const central = new Date(d.getTime() + offsetHours * 3600000);
      hour = central.getUTCHours();
      minute = central.getUTCMinutes();
      // Use central date for CDT/CST determination
      const cY = central.getUTCFullYear();
      const cM = String(central.getUTCMonth() + 1).padStart(2, '0');
      const cD = String(central.getUTCDate()).padStart(2, '0');
      datePart = `${cY}-${cM}-${cD}`;
    } else {
      // Local format (manual edit) — treat as-is
      const [hourStr, minuteStr] = dateStr.split('T')[1].split(':');
      hour = parseInt(hourStr, 10);
      minute = parseInt(minuteStr, 10);
      datePart = dateStr.split('T')[0];
    }

    const hour12 = hour % 12 || 12;
    const ampm = hour >= 12 ? 'PM' : 'AM';
    const tz = isInCDT(datePart) ? 'CDT' : 'CST';
    return `${String(hour12).padStart(2,'0')}:${String(minute).padStart(2,'0')}${ampm}-${tz}`;
  } catch { return null; }
}
---

<ChannelLayout title={channel}>
  {sortedPosts.map(post => (
    <PostCard
      title={post.data.title}
      date={post.data.date}
      time={channel === 'dispatch' ? formatDispatchTime(String(post.data.date ?? '')) ?? undefined : undefined}
      description={post.data.description}
      href={`/${channel}/${post.slug}/`}
    />
  ))}
</ChannelLayout>
