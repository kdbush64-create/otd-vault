---
export const prerender = true;
import ChannelLayout from '../layouts/ChannelLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const channels = ['dispatch', 'transit', 'gear', 'coord', 'table', 'chow', 'xposts'] as const;
  return channels.map(channel => ({ params: { channel } }));
}

type Channel = 'dispatch' | 'transit' | 'gear' | 'coord' | 'table' | 'chow' | 'xposts';
const { channel } = Astro.params as { channel: Channel };
const posts = await getCollection(channel);

// Sort descending by slug — all content slugs are date-prefixed (2026-02-08-title)
// so reverse alpha = newest first
const sortedPosts = [...posts].sort((a, b) => b.slug.localeCompare(a.slug));
---
<ChannelLayout title={channel} description={`All posts in ${channel}`}>
  <div class="post-list">
    {sortedPosts.length === 0 ? (
      <p class="empty-channel">No posts yet in this channel.</p>
    ) : (
      sortedPosts.map(post => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          href={`/${channel}/${post.slug}`}
        />
      ))
    )}
  </div>
</ChannelLayout>
