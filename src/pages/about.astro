---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

let entry: any = null;
try { entry = await getEntry('pages', '00-the-man'); } catch (_) {}
let Content: any = null;
if (entry) { const r = await entry.render(); Content = r.Content; }
---
<BaseLayout title="About" description="About Vintage64TX and v64otd.com">
  <article class="page">
    <h1>About</h1>
    {Content ? <Content /> : <p>About page coming soon.</p>}
  </article>
</BaseLayout>
