---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
let entry: any = null;
try { entry = await getEntry('pages', 'the-man'); } catch (_) {}
let Content: any = null;
if (entry) { const r = await entry.render(); Content = r.Content; }
---
<BaseLayout title="About | OTD Vault" description="About Vintage64TX and v64otd.com">
  <nav class="secondary-filters" style="margin-bottom: 20px; border-bottom: 1px dashed var(--border); padding-bottom: 16px;">
    <a href="/" class="submit-btn" style="text-decoration:none;">&laquo; HOME</a>
  </nav>
  <div class="vault-layout">
    <section style="width: 100%;">
      <h1 style="color:var(--primary); font-size:1.3rem; margin-bottom:20px;">About</h1>
      <hr style="border:none; border-top:1px dashed var(--border); margin-bottom:20px;" />
      <div class="blog-post-body" style="font-size:0.9rem; line-height:1.7;">
        {Content ? <Content /> : <p>About page coming soon.</p>}
      </div>

      <hr style="border:none; border-top:1px dashed var(--border); margin: 30px 0;" />

      <h2 style="color:var(--data-blue); font-size:1rem; letter-spacing:1px; margin-bottom:20px; text-transform:uppercase;">// CONTACT THE OPERATOR</h2>

      <form id="contact-form" style="display:flex; flex-direction:column; gap:16px;">
        <div style="display:flex; gap:16px; flex-wrap:wrap;">
          <div style="flex:1; min-width:180px;">
            <label style="display:block; color:var(--primary); font-size:0.75rem; letter-spacing:1px; margin-bottom:6px; text-transform:uppercase;">First Name *</label>
            <input
              type="text"
              id="firstName"
              name="firstName"
              maxlength="50"
              required
              class="form-input"
              placeholder="FIRST NAME"
            />
            <span class="field-counter" style="font-size:0.65rem; color:var(--secondary); opacity:0.6;" data-for="firstName">0 / 50</span>
          </div>
          <div style="flex:1; min-width:180px;">
            <label style="display:block; color:var(--primary); font-size:0.75rem; letter-spacing:1px; margin-bottom:6px; text-transform:uppercase;">Last Name *</label>
            <input
              type="text"
              id="lastName"
              name="lastName"
              maxlength="50"
              required
              class="form-input"
              placeholder="LAST NAME"
            />
            <span class="field-counter" style="font-size:0.65rem; color:var(--secondary); opacity:0.6;" data-for="lastName">0 / 50</span>
          </div>
        </div>

        <div>
          <label style="display:block; color:var(--primary); font-size:0.75rem; letter-spacing:1px; margin-bottom:6px; text-transform:uppercase;">Email Address *</label>
          <input
            type="email"
            id="email"
            name="email"
            maxlength="254"
            required
            class="form-input"
            placeholder="YOUR@EMAIL.COM"
          />
        </div>

        <div>
          <label style="display:block; color:var(--primary); font-size:0.75rem; letter-spacing:1px; margin-bottom:6px; text-transform:uppercase;">Message * <span id="msg-counter" style="font-size:0.65rem; color:var(--secondary); opacity:0.6;">0 / 1000</span></label>
          <textarea
            id="message"
            name="message"
            maxlength="1000"
            minlength="10"
            required
            rows="6"
            class="form-input"
            placeholder="ENTER YOUR TRANSMISSION..."
            style="resize:vertical; min-height:120px;"
          ></textarea>
          <span id="msg-hint" style="font-size:0.65rem; color:var(--secondary); opacity:0.6;">Minimum 10 characters</span>
        </div>

        <div>
          <button
            type="submit"
            id="submit-btn"
            disabled
            class="submit-btn"
            style="width:100%; opacity:0.4; cursor:not-allowed;"
          >
            TRANSMIT MESSAGE
          </button>
        </div>

        <div id="form-status" style="display:none; padding:10px 14px; font-size:0.82rem; border:1px dashed var(--border);"></div>
      </form>
    </section>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const msgCounter = document.getElementById('msg-counter') as HTMLSpanElement;
  const msgHint = document.getElementById('msg-hint') as HTMLSpanElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;

  const firstName = document.getElementById('firstName') as HTMLInputElement;
  const lastName  = document.getElementById('lastName')  as HTMLInputElement;
  const email     = document.getElementById('email')     as HTMLInputElement;
  const message   = document.getElementById('message')   as HTMLTextAreaElement;

  // Character counters for name fields
  document.querySelectorAll('[data-for]').forEach(counter => {
    const fieldId = (counter as HTMLElement).dataset.for!;
    const field = document.getElementById(fieldId) as HTMLInputElement;
    field.addEventListener('input', () => {
      counter.textContent = `${field.value.length} / 50`;
    });
  });

  // Message counter
  message.addEventListener('input', () => {
    const len = message.value.length;
    msgCounter.textContent = `${len} / 1000`;
    msgHint.textContent = len < 10 ? `Minimum 10 characters (${10 - len} more needed)` : '';
    validate();
  });

  // Email validation
  function isValidEmail(val: string) {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
  }

  function validate() {
    const ok =
      firstName.value.trim().length > 0 &&
      lastName.value.trim().length > 0 &&
      isValidEmail(email.value.trim()) &&
      message.value.trim().length >= 10;

    submitBtn.disabled = !ok;
    submitBtn.style.opacity = ok ? '1' : '0.4';
    submitBtn.style.cursor = ok ? 'pointer' : 'not-allowed';
  }

  [firstName, lastName, email].forEach(f => f.addEventListener('input', validate));

  // Submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'TRANSMITTING...';

    const formData = new FormData(form);

    try {
      const res = await fetch('/api/contact', { method: 'POST', body: formData });
      const json = await res.json();

      statusDiv.style.display = 'block';
      if (res.ok) {
        statusDiv.style.color = 'var(--accent)';
        statusDiv.style.borderColor = 'var(--accent)';
        statusDiv.textContent = '✅ TRANSMISSION RECEIVED — We will respond to your inquiry shortly.';
        form.reset();
        msgCounter.textContent = '0 / 1000';
        validate();
        submitBtn.textContent = 'TRANSMIT MESSAGE';
      } else {
        statusDiv.style.color = 'var(--error)';
        statusDiv.style.borderColor = 'var(--error)';
        statusDiv.textContent = '⚠ TRANSMISSION FAILED — Please try again or contact us directly.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'TRANSMIT MESSAGE';
      }
    } catch {
      statusDiv.style.display = 'block';
      statusDiv.style.color = 'var(--error)';
      statusDiv.style.borderColor = 'var(--error)';
      statusDiv.textContent = '⚠ TRANSMISSION FAILED — Network error. Please try again.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'TRANSMIT MESSAGE';
    }
  });
</script>
