---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
let entry: any = null;
try { entry = await getEntry('pages', 'the-man'); } catch (_) {}
let Content: any = null;
if (entry) { const r = await entry.render(); Content = r.Content; }
---

<BaseLayout title="About | OTD Vault" description="About Vintage64TX and v64otd.com">

  <div class="about-page">

    <nav class="about-breadcrumb">
      <a href="/">← Home</a>
    </nav>

    <header class="about-header">
      <p class="about-eyebrow">THE OPERATOR</p>
      <h1 class="about-title">About: Old Texas Dude</h1>
    </header>

    <figure class="about-portrait">
      <img
        src="/images/profile/v64otd-mastodon-avatar.jpg"
        alt="Old Texas Dude — I-35 South, Fort Worth"
        class="about-portrait-img"
      />
      <figcaption class="about-portrait-caption">I-35 South. Fort Worth. The brisket was cold. The dispatch was not.</figcaption>
    </figure>

    <div class="about-body">
      {Content ? <Content /> : <p>About page coming soon.</p>}
    </div>

    <hr class="about-rule" />

    <!-- Channel grid -->
    <section class="channels-section">
      <h2 class="channels-heading">What's in the Vault</h2>
      <div class="channels-grid">
        <a href="/dispatch" class="channel-card ch-ink">
          <h3 class="ch-title">Dispatch</h3>
          <p class="ch-desc">Long-form essays, cultural analysis, and the occasional thing that will make someone on the internet angry. If you read one channel, read this one.</p>
          <span class="ch-link">Browse dispatches →</span>
        </a>
        <a href="/gear" class="channel-card ch-cedar">
          <h3 class="ch-title">Gear</h3>
          <p class="ch-desc">Tools, tech, and equipment worth owning. Not sponsored. Not curated for a demographic. Just things that work.</p>
          <span class="ch-link">Browse gear →</span>
        </a>
        <a href="/table" class="channel-card ch-clay">
          <h3 class="ch-title">The Table</h3>
          <p class="ch-desc">Food culture and restaurant reviews. Brisket is taken seriously here. Fusion tacos are evaluated on a case-by-case basis.</p>
          <span class="ch-link">Browse restaurants →</span>
        </a>
        <a href="/chow" class="channel-card ch-ochre">
          <h3 class="ch-title">The Kitchen</h3>
          <p class="ch-desc">Recipes. Real ones. The kind that work in a home kitchen without a culinary degree or a Vitamix.</p>
          <span class="ch-link">Browse kitchen →</span>
        </a>
        <a href="/transit" class="channel-card ch-cedar">
          <h3 class="ch-title">Travel</h3>
          <p class="ch-desc">Roads, routes, road trips, and the American habit of going somewhere to figure out what you think.</p>
          <span class="ch-link">Browse travel →</span>
        </a>
        <a href="/coord" class="channel-card ch-cedar">
          <h3 class="ch-title">Getaways</h3>
          <p class="ch-desc">Places. Fort Worth, DFW, Texas, and points beyond. Honest assessments from someone who has eaten bad barbecue in too many states to stay quiet.</p>
          <span class="ch-link">Browse getaways →</span>
        </a>
      </div>
    </section>

    <hr class="about-rule" />

    <section class="contact-section">
      <h2 class="contact-heading">Contact the Operator</h2>
      <form id="contact-form" class="contact-form">
        <div class="form-row">
          <div class="form-field">
            <label for="firstName" class="form-label">First Name <span class="required">*</span></label>
            <input type="text" id="firstName" name="firstName" maxlength="50" required class="form-input" placeholder="First name" />
            <span class="field-counter" data-for="firstName">0 / 50</span>
          </div>
          <div class="form-field">
            <label for="lastName" class="form-label">Last Name <span class="required">*</span></label>
            <input type="text" id="lastName" name="lastName" maxlength="50" required class="form-input" placeholder="Last name" />
            <span class="field-counter" data-for="lastName">0 / 50</span>
          </div>
        </div>
        <div class="form-field">
          <label for="email" class="form-label">Email Address <span class="required">*</span></label>
          <input type="email" id="email" name="email" maxlength="254" required class="form-input" placeholder="your@email.com" />
        </div>
        <div class="form-field">
          <label for="message" class="form-label">
            Message <span class="required">*</span>
            <span id="msg-counter" class="msg-counter">0 / 1000</span>
          </label>
          <textarea id="message" name="message" maxlength="1000" minlength="10" required rows="6" class="form-input" placeholder="Your message..."></textarea>
          <span id="msg-hint" class="field-hint">Minimum 10 characters</span>
        </div>
        <div class="form-field">
          <button type="submit" id="submit-btn" disabled class="submit-btn">Send Message</button>
        </div>
        <div id="form-status" class="form-status" style="display:none;"></div>
      </form>
    </section>

  </div>

</BaseLayout>

<style>
.about-portrait { margin: 0 0 2rem; }
  .about-portrait-img {
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    object-position: center top;
    border-radius: 4px;
    display: block;
  }
  .about-portrait-caption {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    color: rgba(43,37,32,0.5);
    margin-top: 0.5rem;
    display: block;
  }  
.about-page { max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .about-breadcrumb { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.06em; margin-bottom: 2rem; }
  .about-breadcrumb a { color: rgba(43,37,32,0.55); text-decoration: none; }
  .about-breadcrumb a:hover { color: var(--clay); }
  .about-eyebrow { font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; letter-spacing: 0.14em; color: var(--cedar); text-transform: uppercase; margin: 0 0 0.5rem; }
  .about-title { font-family: 'Fraunces', serif; font-size: clamp(1.8rem, 5vw, 2.5rem); font-weight: 700; color: var(--ink); margin: 0 0 2rem; line-height: 1.15; }
  .about-body { font-family: 'Inter', sans-serif; font-size: 1.02rem; line-height: 1.75; color: var(--ink); }
  .about-body :global(p) { margin: 0 0 1.25em; }
  .about-body :global(h2) { font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 600; margin: 2rem 0 0.5rem; color: var(--ink); }
  .about-body :global(strong) { font-weight: 600; }
  .about-body :global(a) { color: var(--clay); text-underline-offset: 3px; }
  .about-rule { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }

  /* Channel grid */
  .channels-section { margin-bottom: 0.5rem; }
  .channels-heading { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 600; color: var(--ink); margin: 0 0 1.25rem; }
  .channels-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; }
  .channel-card { display: flex; flex-direction: column; gap: 0.4rem; background: var(--card-bg); border: 1.5px solid var(--border); border-radius: 4px; padding: 1.25rem; text-decoration: none; color: var(--ink); transition: transform 0.15s, box-shadow 0.15s; }
  .channel-card:hover { transform: translateY(-2px); box-shadow: 0 4px 14px rgba(43,37,32,0.09); }
  .ch-ink   { border-top: 3px solid var(--ink); }
  .ch-cedar { border-top: 3px solid var(--cedar); }
  .ch-clay  { border-top: 3px solid var(--clay); }
  .ch-ochre { border-top: 3px solid var(--ochre); }
  .ch-title { font-family: 'Fraunces', serif; font-size: 1rem; font-weight: 600; color: var(--ink); margin: 0; }
  .ch-desc { font-family: 'Inter', sans-serif; font-size: 0.82rem; color: rgba(43,37,32,0.65); line-height: 1.5; margin: 0; flex: 1; }
  .ch-link { font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; color: var(--clay); margin-top: 0.35rem; }

  /* Contact form */
  .contact-heading { font-family: 'Fraunces', serif; font-size: 1.4rem; font-weight: 600; color: var(--ink); margin: 0 0 1.5rem; }
  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .form-row { display: flex; gap: 1rem; flex-wrap: wrap; }
  .form-row .form-field { flex: 1; min-width: 180px; }
  .form-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .form-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(43,37,32,0.65); display: flex; align-items: center; gap: 0.4rem; }
  .required { color: var(--clay); }
  .form-input { font-family: 'Inter', sans-serif; font-size: 0.95rem; padding: 0.65rem 0.9rem; border: 1.5px solid var(--border); border-radius: 2px; background: #fff; color: var(--ink); width: 100%; box-sizing: border-box; }
  .form-input:focus { outline: 2px solid var(--clay); border-color: transparent; }
  textarea.form-input { resize: vertical; min-height: 130px; }
  .field-counter, .field-hint { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; color: rgba(43,37,32,0.45); }
  .msg-counter { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; color: rgba(43,37,32,0.45); margin-left: auto; }
  .submit-btn { font-family: 'IBM Plex Mono', monospace; font-size: 0.82rem; letter-spacing: 0.08em; background: var(--clay); color: #fff; border: none; padding: 0.75rem 1.5rem; border-radius: 2px; cursor: pointer; width: 100%; transition: opacity 0.15s; }
  .submit-btn:hover:not(:disabled) { opacity: 0.88; }
  .submit-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .form-status { font-family: 'Inter', sans-serif; font-size: 0.88rem; padding: 0.75rem 1rem; border: 1.5px solid var(--border); border-radius: 2px; line-height: 1.5; }
  .form-status.success { color: var(--cedar); border-color: var(--cedar); }
  .form-status.error { color: var(--clay); border-color: var(--clay); }
</style>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn  = document.getElementById('submit-btn')   as HTMLButtonElement;
  const msgCounter = document.getElementById('msg-counter')  as HTMLSpanElement;
  const msgHint    = document.getElementById('msg-hint')     as HTMLSpanElement;
  const statusDiv  = document.getElementById('form-status')  as HTMLDivElement;
  const firstName  = document.getElementById('firstName')    as HTMLInputElement;
  const lastName   = document.getElementById('lastName')     as HTMLInputElement;
  const email      = document.getElementById('email')        as HTMLInputElement;
  const message    = document.getElementById('message')      as HTMLTextAreaElement;

  document.querySelectorAll('[data-for]').forEach(counter => {
    const fieldId = (counter as HTMLElement).dataset.for!;
    const field = document.getElementById(fieldId) as HTMLInputElement;
    field.addEventListener('input', () => { counter.textContent = `${field.value.length} / 50`; });
  });
  message.addEventListener('input', () => {
    const len = message.value.length;
    msgCounter.textContent = `${len} / 1000`;
    msgHint.textContent = len < 10 ? `${10 - len} more characters needed` : '';
    validate();
  });
  function isValidEmail(val: string) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val); }
  function validate() {
    const ok = firstName.value.trim().length > 0 && lastName.value.trim().length > 0 &&
      isValidEmail(email.value.trim()) && message.value.trim().length >= 10;
    submitBtn.disabled = !ok;
  }
  [firstName, lastName, email].forEach(f => f.addEventListener('input', validate));
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    try {
      const res = await fetch('/api/contact', { method: 'POST', body: new FormData(form) });
      statusDiv.style.display = 'block';
      if (res.ok) {
        statusDiv.className = 'form-status success';
        statusDiv.textContent = "Message received — we'll be in touch shortly.";
        form.reset(); msgCounter.textContent = '0 / 1000'; validate();
        submitBtn.textContent = 'Send Message';
      } else {
        statusDiv.className = 'form-status error';
        statusDiv.textContent = 'Something went wrong. Please try again.';
        submitBtn.disabled = false; submitBtn.textContent = 'Send Message';
      }
    } catch {
      statusDiv.style.display = 'block';
      statusDiv.className = 'form-status error';
      statusDiv.textContent = 'Network error. Please try again.';
      submitBtn.disabled = false; submitBtn.textContent = 'Send Message';
    }
  });
</script>
